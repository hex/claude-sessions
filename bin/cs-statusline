#!/usr/bin/env bash
# ABOUTME: Claude Code statusLine command — renders one line of squared, abutting pills
# ABOUTME: Reads the statusline JSON on stdin and prints session/ctx/model/git/limits/cost

set -uo pipefail

SESSIONS_ROOT="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"

# Read-only status query; never take the index lock from a render.
export GIT_OPTIONAL_LOCKS=0

# KEEP IN SYNC with lib/02-platform.sh
# Returns one of: macos | wsl | msys | linux   (cached after first detect)
cs_platform() {
    # Test/override seam: FIRST branch, validated, cache-bypassing.
    if [ -n "${CS_PLATFORM_OVERRIDE:-}" ]; then
        case "$CS_PLATFORM_OVERRIDE" in
            macos|wsl|msys|linux) printf '%s' "$CS_PLATFORM_OVERRIDE"; return 0 ;;
            *) printf 'cs: invalid CS_PLATFORM_OVERRIDE: %s\n' "$CS_PLATFORM_OVERRIDE" >&2; return 1 ;;
        esac
    fi
    [ -n "${_CS_PLATFORM:-}" ] && { printf '%s' "$_CS_PLATFORM"; return 0; }
    local p
    case "$(uname -s 2>/dev/null)" in
        Darwin) p=macos ;;
        MINGW*|MSYS*|CYGWIN*) p=msys ;;
        Linux)
            if [ -n "${WSL_DISTRO_NAME:-}" ] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
                p=wsl
            else
                p=linux
            fi ;;
        *) p=linux ;;
    esac
    _CS_PLATFORM="$p"; printf '%s' "$p"
}

# Resolve SL_THEME for this render. CS_TERM_THEME set on its own (no
# CS_TERM_THEME_AUTO marker) is an explicit user pin (see `cs -help`) and wins.
# When launch auto-detected the theme it exports CS_TERM_THEME plus the
# CS_TERM_THEME_AUTO=1 marker: that value can't follow a mid-session terminal
# theme switch (macOS auto dark mode), and re-querying the terminal here would
# corrupt claude's TUI, so on macOS read the live OS appearance instead. Assigns
# SL_THEME directly rather than via `$(...)`, per this file's fork-free-hot-path
# convention. KEEP the macOS branch IN SYNC with _theme_from_os_appearance in
# lib/70-statusline.sh.
_sl_detect_theme() {
    if [ -n "${CS_TERM_THEME:-}" ] && [ -z "${CS_TERM_THEME_AUTO:-}" ]; then
        SL_THEME="$CS_TERM_THEME"
    elif [[ "${OSTYPE:-}" == darwin* ]]; then
        if defaults read -g AppleInterfaceStyle >/dev/null 2>&1; then SL_THEME="dark"; else SL_THEME="light"; fi
    else
        # Off macOS keep the theme cs detected at launch (CS_TERM_THEME).
        SL_THEME="${CS_TERM_THEME:-light}"
    fi
}

# Blank CS_TERM_BG_RGB when the launch-captured background is stale: once the
# live theme (SL_THEME) has switched away from the theme cs detected at launch
# (CS_TERM_THEME, present with the auto marker), the RGB no longer matches the
# terminal, so drop it and let the gauge surface and gradient fall back to
# theme-based values instead of tinting toward the old background (which could
# leave light text on a near-light surface). A manually-set RGB carries no auto
# marker and is never dropped.
_sl_invalidate_stale_bg() {
    if [ -n "${CS_TERM_BG_RGB:-}" ] && [ -n "${CS_TERM_THEME_AUTO:-}" ] && [ "$SL_THEME" != "${CS_TERM_THEME:-}" ]; then
        CS_TERM_BG_RGB=""
    fi
}

_sl_detect_theme
_sl_invalidate_stale_bg

# Parsed stdin fields (filled by _parse_stdin).
SL_SESSION=""; SL_CTX=""; SL_MODEL=""; SL_EFFORT=""
SL_5H=""; SL_5H_RESET=""; SL_WK=""; SL_WK_RESET=""; SL_COST=""; SL_DIR=""

# Collected segments (parallel arrays) and chosen color level.
_SEG_TEXT=(); _SEG_BG=(); _SEG_BOLD=(); LEVEL="basic"

# Scratch globals used in place of command substitution (keeps the per-render
# hot path fork-free; this script runs on every assistant message).
_SGR=""; _COLOR=""; _RGB=""
_WIDTH=""; _LC=""; _R=""; _G=""; _B=""; _GRADIENT=""; _LUM=""
# The gauge surface is a shade of the terminal background — the same for every
# gauge — so it is resolved once per render (process) and cached here.
_SURFACE_RGB=""

# Per-segment icons. Standard Unicode (Geometric Shapes + dingbats) that render
# in any monospace font — not Nerd Font private-use glyphs — so the bar looks
# right without a patched font. The session segment carries no icon.
ICON_CTX=$'\xe2\x97\x94 '       # U+25D4 quadrant circle (gauge)
ICON_MODEL=$'\xe2\x9c\xa6 '     # U+2726 four-pointed star
ICON_GIT=$'\xe2\x8e\x87 '       # U+2387 branch
ICON_5H=$'\xe2\x97\xb7 '        # U+25F7 clock
ICON_WK=$'\xe2\x97\x91 '        # U+25D1 half circle
ICON_NOTES=$'\xe2\x96\xa4 '     # U+25A4 square with horizontal fill (notes queue)
ICON_LOGO=$'\xe2\x9c\xb3'       # U+2733 eight-spoked asterisk (Claude mark)
ICON_PANE=$'\xe2\x97\xab '      # U+25EB square with vertical bisect (tmux pane)

# --- stdin -----------------------------------------------------------------

# Run a command with a wall-clock cap when timeout(1) is available, else plain.
_timeout() {
    local secs="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$secs" "$@"
    else
        "$@"
    fi
}

# Slurp stdin into _STDIN with a builtin read so no subprocess is spawned and
# a stuck pipe cannot hang the render past one second. Handles single-line
# compact JSON (the common case) and multi-line pretty JSON alike.
_read_stdin() {
    _STDIN=""
    [ -t 0 ] && return 0
    local line=""
    while IFS= read -r -t 1 line; do
        _STDIN+="$line"$'\n'
    done
    _STDIN+="$line"   # trailing partial line (no newline) or empty
}

# Current epoch for this render, read at most once. Honors CS_STATUSLINE_NOW
# (test/pin), then the fork-free printf builtin, then a date fork (macOS bash
# 3.2 lacks %(...)T). Memoized so the limits stamp, countdown, and attention
# pulse share one clock instead of forking date up to three times a render.
# The memo gate is a dedicated flag, not the value: even when every clock source
# fails and _NOW ends empty, the flag records that this render already tried, so
# a later caller does not re-fork date. main() zeroes both _NOW and the flag at
# render start, so an inherited value can never seed the memo. Always overwrites
# _NOW in-process and validates it numeric; leaves it empty when every source
# fails, so callers apply their own fallback.
_sl_now() {
    [ -n "${_SL_NOW_READY:-}" ] && return 0
    _SL_NOW_READY=1
    if [ -n "${CS_STATUSLINE_NOW:-}" ]; then
        _NOW="$CS_STATUSLINE_NOW"
    else
        printf -v _NOW '%(%s)T' -1 2>/dev/null
        [[ "${_NOW:-}" =~ ^[0-9]+$ ]] || _NOW=$(date +%s 2>/dev/null)
    fi
    # Normalize to canonical base-10: a leading-zero value (e.g. a pin of 08) is
    # read as octal by bash arithmetic and aborts on an 8/9 digit. 10# forces
    # base-10 so the countdown, stamp, and pulse all get a safe integer.
    if [[ "${_NOW:-}" =~ ^[0-9]+$ ]]; then _NOW=$((10#$_NOW)); else _NOW=""; fi
}

# Extract every field we need in one jq pass, one value per line. Returns
# non-zero (caller falls back) when jq is missing, stdin is empty, or the JSON
# does not parse. One value per line (not @tsv) because `read` collapses
# consecutive tab delimiters, which would drop empty fields and shift values.
_parse_stdin() {
    local input="$1" fields
    command -v jq >/dev/null 2>&1 || return 1
    [ -n "$input" ] || return 1
    fields=$(printf '%s' "$input" | jq -r '
        [ (.session_name // ""),
          (.context_window.used_percentage // "" | tostring),
          (.model.display_name // ""),
          (.effort.level // ""),
          (.rate_limits.five_hour.used_percentage // "" | tostring),
          (.rate_limits.five_hour.resets_at // "" | tostring),
          (.rate_limits.seven_day.used_percentage // "" | tostring),
          (.rate_limits.seven_day.resets_at // "" | tostring),
          (.cost.total_cost_usd // "" | tostring),
          (.workspace.current_dir // .cwd // "")
        ] | .[]' 2>/dev/null) || return 1
    # Native jq.exe on Windows emits CRLF line terminators; `read` splits on \n
    # and would leave a trailing \r on every field. Strip them so numeric gauges
    # stay numeric and text fields don't carry an invisible carriage return.
    fields=${fields//$'\r'/}
    {
        IFS= read -r SL_SESSION
        IFS= read -r SL_CTX
        # Stamp context % for the task-queue gate (the Stop hook reads this file).
        # Machine-local, per the .cs/local partition; truncated to an integer.
        if [ -n "${CLAUDE_SESSION_NAME:-}" ] && [ -n "${SL_CTX:-}" ]; then
            _pctdir="$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/local"
            if mkdir -p "$_pctdir" 2>/dev/null; then
                printf '%s\n' "${SL_CTX%%.*}" > "$_pctdir/context-pct.tmp" 2>/dev/null \
                    && mv "$_pctdir/context-pct.tmp" "$_pctdir/context-pct" 2>/dev/null || true
            fi
        fi
        IFS= read -r SL_MODEL
        IFS= read -r SL_EFFORT
        IFS= read -r SL_5H
        IFS= read -r SL_5H_RESET
        IFS= read -r SL_WK
        IFS= read -r SL_WK_RESET
        IFS= read -r SL_COST
        IFS= read -r SL_DIR
    } <<EOF
$fields
EOF
    # Stamp rate-limit state for cs -usage window anchoring. Same partition
    # rules as context-pct: machine-local, atomic, best-effort.
    if [ -n "${CLAUDE_SESSION_NAME:-}" ] && { [ -n "${SL_5H:-}" ] || [ -n "${SL_WK:-}" ]; }; then
        _limdir="$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/local"
        if mkdir -p "$_limdir" 2>/dev/null; then
            _sl_now
            {
                printf 'five_hour_used_pct: %s\n' "${SL_5H%%.*}"
                printf 'five_hour_resets_at: %s\n' "${SL_5H_RESET:-}"
                printf 'seven_day_used_pct: %s\n' "${SL_WK%%.*}"
                printf 'seven_day_resets_at: %s\n' "${SL_WK_RESET:-}"
                printf 'stamped_at: %s\n' "${_NOW}"
            } > "$_limdir/limits.tmp" 2>/dev/null \
                && mv "$_limdir/limits.tmp" "$_limdir/limits" 2>/dev/null || true
        fi
    fi
    return 0
}

# Print the dir basename as a last-resort plain status, then exit cleanly.
_fallback() {
    printf '%s\n' "$(basename "${PWD:-/}")"
    exit 0
}

# --- color ladder ----------------------------------------------------------

# Choose the richest color level the terminal advertises.
_detect_level() {
    if [ "${FORCE_COLOR:-}" = "0" ] || [ -n "${NO_COLOR:-}" ] || [ "${TERM:-}" = "dumb" ]; then
        LEVEL="plain"
    elif [ "${COLORTERM:-}" = "truecolor" ] || [ "${COLORTERM:-}" = "24bit" ] \
        || [ "${TERM_PROGRAM:-}" = "iTerm.app" ] || [ "${TERM_PROGRAM:-}" = "WezTerm" ]; then
        LEVEL="truecolor"
    elif [[ "${TERM:-}" == *256color* ]]; then
        LEVEL="256"
    else
        LEVEL="basic"
    fi
}

# Set _SGR to the SGR parameters painting a color name for the active level.
# $1 = 38 (foreground) or 48 (background); $2 = color name. No subprocess.
_sgr() {
    local kind="$1" name="$2"
    case "$LEVEL" in
        truecolor)
            local rgb
            case "$name" in
                # Session-color palette: Claude Code's own /color values (the
                # shared dark/light theme `*_FOR_SUBAGENTS_ONLY` tokens), so the
                # session pill matches CC's session accent and the terminal tab.
                # KEEP IN SYNC with _session_color_rgb in bin/cs (tab color).
                red)    rgb="220;38;38" ;;
                blue)   rgb="106;155;204" ;;
                green)  rgb="22;163;74" ;;
                yellow) rgb="202;138;4" ;;
                purple) rgb="130;125;189" ;;
                orange) rgb="217;119;87" ;;
                pink)   rgb="196;102;134" ;;
                cyan)   rgb="8;145;178" ;;
                periwinkle) rgb="138;134;236" ;;
                slate)  rgb="79;91;140" ;;
                chiptext) rgb="240;242;255" ;;
                rowname)
                    # A subagent row's agent name sits on the bare terminal, not
                    # a pill, so it takes ink that contrasts the canvas: near-white
                    # on a dark terminal, dark on a light one.
                    [ "$SL_THEME" = "dark" ] && rgb="240;242;255" || rgb="48;42;36" ;;
                rowmeta)
                    # The row's description, ctx and elapsed: quieter than the
                    # name, still readable against the terminal on either theme.
                    [ "$SL_THEME" = "dark" ] && rgb="170;161;148" || rgb="128;116;106" ;;
                amber)  rgb="255;183;77" ;;
                brand)  rgb="217;119;87" ;;   # Claude coral (#D97757)
                brandshade)
                    # The logo badge's own divider ink: a coral a shade darker
                    # than the badge, distinct enough to read as a divider
                    # sliver against both the badge and the session pill,
                    # without being so dark it looks like a foreign color.
                    rgb="184;101;74" ;;
                white)
                    # Softer text on dark terminals to avoid glare.
                    [ "$SL_THEME" = "dark" ] && rgb="230;230;230" || rgb="255;255;255" ;;
                black)  rgb="30;30;30" ;;
                hairline)
                    # The thin divider between same-background pills: a light
                    # warm grey, lighter than the taupe block but softer than
                    # the white label text, so it reads as a faint line.
                    rgb="170;161;148" ;;
                surface)
                    # The quiet gauge pills, tinted from the terminal background
                    # so they harmonize with it instead of sitting on top: a
                    # shade of CS_TERM_BG_RGB (darker on a light terminal,
                    # lighter on a dark one), resolved once per render and cached
                    # since every gauge shares it. Falls back to the warm neutral
                    # when the real background is unknown (no OSC 11 at launch).
                    if [ -z "$_SURFACE_RGB" ]; then
                        if _bg_shade "${CS_TERM_BG_RGB:-}"; then _SURFACE_RGB="$_R;$_G;$_B"
                        elif [ "$SL_THEME" = "dark" ]; then _SURFACE_RGB="140;132;122"
                        else _SURFACE_RGB="128;120;110"; fi
                    fi
                    rgb="$_SURFACE_RGB" ;;
                *)
                    # Warm neutral (R>G>B) so the quiet blocks read as taupe,
                    # not steel; light enough that the gauges recede beside the
                    # vivid session/model accents while white label text holds.
                    [ "$SL_THEME" = "dark" ] && rgb="140;132;122" || rgb="128;120;110" ;;
            esac
            _SGR="${kind};2;${rgb}"; _RGB="$rgb" ;;
        256)
            local idx
            case "$name" in
                red)    idx=160 ;;
                blue)   idx=25 ;;
                green)  idx=28 ;;
                yellow) idx=136 ;;
                purple) idx=55 ;;
                orange) idx=166 ;;
                pink)   idx=162 ;;
                cyan)   idx=30 ;;
                periwinkle) idx=105 ;;
                slate)  idx=60 ;;
                chiptext) idx=231 ;;
                rowname) [ "$SL_THEME" = "dark" ] && idx=231 || idx=235 ;;
                rowmeta) [ "$SL_THEME" = "dark" ] && idx=248 || idx=244 ;;
                amber)  idx=215 ;;
                brand)  idx=173 ;;
                brandshade) idx=167 ;;
                hairline) idx=248 ;;
                white)
                    [ "$SL_THEME" = "dark" ] && idx=254 || idx=255 ;;
                black)  idx=235 ;;
                *)
                    [ "$SL_THEME" = "dark" ] && idx=245 || idx=244 ;;
            esac
            _SGR="${kind};5;${idx}" ;;
        *)
            local base
            case "$name" in
                red)    base=31 ;;
                blue)   base=34 ;;
                green)  base=32 ;;
                yellow) base=33 ;;
                purple) base=35 ;;
                orange) base=33 ;;
                pink)   base=95 ;;
                cyan)   base=36 ;;
                periwinkle) base=94 ;;
                slate)  base=34 ;;
                chiptext) base=97 ;;
                rowname) [ "$SL_THEME" = "dark" ] && base=97 || base=30 ;;
                rowmeta) base=90 ;;
                amber)  base=33 ;;
                white)  base=97 ;;
                black)  base=30 ;;
                brand)  base=33 ;;
                brandshade) base=33 ;;
                hairline) base=90 ;;
                *)      base=90 ;;
            esac
            if [ "$kind" = "48" ]; then _SGR=$((base + 10)); else _SGR="$base"; fi ;;
    esac
}

# --- segment helpers -------------------------------------------------------

# Append a segment (text + background color name).
_add() {
    _SEG_TEXT+=("$1")
    _SEG_BG+=("$2")
    _SEG_BOLD+=("${3:-}")
}

# Set _COLOR by mapping a value against warn/crit thresholds; below warn it
# takes the healthy color ($4, default the bg-derived surface).
_thresh_color() {
    local v="$1" warn="$2" crit="$3" healthy="${4:-surface}"
    if [ "$v" -ge "$crit" ]; then
        _COLOR=red
    elif [ "$v" -ge "$warn" ]; then
        _COLOR=amber
    else
        _COLOR="$healthy"
    fi
}

# Format seconds-until-reset into a compact "2h14m" / "45m" countdown in _REST.
# $1 is the resets_at value (Unix epoch seconds, per the statusline schema).
# Empty when it is missing, non-numeric, or already in the past. `now` comes
# from the printf builtin (bash 4.2+) so the hot path stays fork-free; on an
# older bash (e.g. macOS stock 3.2) the builtin is unavailable, so it falls
# back to a `date +%s` fork so the countdown still renders.
_fmt_rest() {
    _REST=""
    local at="$1" now rem h m
    [[ "$at" =~ ^[0-9]+$ ]] || return 0
    # Shared per-render clock (see _sl_now); empty only if every source failed.
    _sl_now
    now="${_NOW:-}"
    [[ "$now" =~ ^[0-9]+$ ]] || return 0
    rem=$(( at - now ))
    [ "$rem" -gt 0 ] || return 0
    h=$(( rem / 3600 ))
    m=$(( (rem % 3600) / 60 ))
    if [ "$h" -gt 0 ]; then
        _REST="${h}h${m}m"
    elif [ "$m" -gt 0 ]; then
        _REST="${m}m"
    else
        _REST="<1m"
    fi
}

# Read claude_session_color from a session's machine-local state file
# (.cs/local/state) into _SESSION_COLOR (empty if none). Pure bash: this runs
# once per render, where an awk fork is real cost. KEEP THE FORMAT IN SYNC
# WITH bin/cs's _read_local_state.
_read_session_color() {
    _SESSION_COLOR=""
    local state="$1" line v
    [ -f "$state" ] || return 0
    while IFS= read -r line; do
        case "$line" in
            claude_session_color:*)
                v="${line#claude_session_color:}"
                v="${v#"${v%%[![:space:]]*}"}"
                _SESSION_COLOR="${v//\"/}"
                return 0
                ;;
        esac
    done < "$state"
}

# Format the git segment text for a workspace dir into _GIT_TEXT, empty when
# it is not a git repo / git is unavailable / git times out.
_git_text() {
    _GIT_TEXT=""
    local dir="$1"
    [ -n "$dir" ] || return 0
    [ -e "$dir/.git" ] || return 0
    local out
    out=$(_timeout 2 git -C "$dir" status --porcelain=v1 -b 2>/dev/null) || return 0
    local branch="" ahead=0 behind=0 staged=0 modified=0 first=1 line x y h
    while IFS= read -r line; do
        if [ "$first" = "1" ]; then
            first=0
            h="${line#\#\# }"
            case "$h" in
                "No commits yet on "*) branch="${h#No commits yet on }" ;;
                "HEAD (no branch)")    branch="HEAD" ;;
                *)
                    branch="${h%%...*}"
                    [[ "$h" =~ ahead\ ([0-9]+) ]] && ahead="${BASH_REMATCH[1]}"
                    [[ "$h" =~ behind\ ([0-9]+) ]] && behind="${BASH_REMATCH[1]}"
                    ;;
            esac
        else
            x="${line:0:1}"; y="${line:1:1}"
            # Untracked entries are `??` in both columns; exclude `?` from both
            # counts so untracked files do not show as a phantom modified `!`.
            [ "$x" != " " ] && [ "$x" != "?" ] && staged=$((staged + 1))
            [ "$y" != " " ] && [ "$y" != "?" ] && modified=$((modified + 1))
        fi
    done <<EOF
$out
EOF
    [ -n "$branch" ] || return 0
    local text="$branch"
    # Brace the expansion: a bare $text↑ would let set -u read the arrow's first
    # UTF-8 byte as part of the variable name and abort on "unbound variable".
    [ "$ahead" -gt 0 ] && text="${text}↑${ahead}"
    [ "$behind" -gt 0 ] && text="${text}↓${behind}"
    local marks=""
    [ "$staged" -gt 0 ] && marks="+$staged"
    [ "$modified" -gt 0 ] && marks="$marks!$modified"
    [ -n "$marks" ] && text="$text $marks"
    _GIT_TEXT="$text"
}

# --- segments --------------------------------------------------------------

# A brand badge: the Claude mark on the Claude-coral background, opening the
# bar. Icon only, no label; the render's own padding squares it off. The badge
# is the background, so it is omitted when color is off (plain has none).
# While the session's attention marker exists (raised by the Stop hook when
# Claude finishes a turn, cleared on the next prompt) the mark's color pulses.
_seg_logo() {
    [ "$LEVEL" = "plain" ] && return 0
    local attr=bold
    [ -n "${CLAUDE_SESSION_NAME:-}" ] \
        && [ -f "$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/local/attention" ] \
        && attr=boldattention
    _add "${ICON_LOGO}" "brand" "$attr"
}

_seg_session() {
    local name="$SL_SESSION"
    [ -n "$name" ] || name="${CLAUDE_SESSION_NAME:-}"
    if [ -z "$name" ]; then
        local dir="${SL_DIR:-$PWD}"
        name="${dir##*/}"
    fi
    local bg="grey" color=""
    if [ -n "${CLAUDE_SESSION_NAME:-}" ]; then
        _read_session_color "$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/local/state"
        color="$_SESSION_COLOR"
        [ -n "$color" ] && bg="$color"
    fi
    _add "${name}" "$bg" bold
}

# Count of queued tasks for the current session (.cs/local/queue), shown right
# after the session name. Hidden when the queue is empty or absent.
_seg_notes() {
    [ -n "${CLAUDE_SESSION_NAME:-}" ] || return 0
    local qf="$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/local/queue"
    [ -f "$qf" ] || return 0
    # Count non-blank lines (awk NF equivalent) without an awk fork; this runs
    # every render. A whitespace-only line is not a task. `|| [ -n "$line" ]`
    # counts a torn final line lacking a trailing newline, matching awk's read.
    local n=0 line
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            *[![:space:]]*) n=$((n + 1)) ;;
        esac
    done < "$qf"
    [ "$n" -gt 0 ] || return 0
    _add "${ICON_NOTES}${n}" "amber"
}

# The tmux pane hosting this conversation, as a target usable verbatim in
# tmux commands and other chats ("%7"). TMUX_PANE is inherited environment,
# so this adds zero forks to the render hot path; both vars are required so
# a stale TMUX_PANE outside a live tmux client never renders.
_seg_pane() {
    [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ] || return 0
    _add "${ICON_PANE}${TMUX_PANE}" "grey"
}

_seg_ctx() {
    local v="${SL_CTX%%.*}"
    [ -n "$v" ] || return 0
    local warn="${CS_STATUSLINE_CTX_WARN:-50}" crit="${CS_STATUSLINE_CTX_CRIT:-80}"
    _thresh_color "$v" "$warn" "$crit"
    _add "${ICON_CTX}ctx ${v}%" "$_COLOR"
}

_seg_model() {
    [ -n "$SL_MODEL" ] || return 0
    local t="$SL_MODEL"
    [ -n "$SL_EFFORT" ] && t="$t $SL_EFFORT"
    _add "${ICON_MODEL}${t}" "periwinkle" bold
}

_seg_git() {
    _git_text "$SL_DIR"
    local t="$_GIT_TEXT"
    [ -n "$t" ] || return 0
    _add "${ICON_GIT}${t}" "slate" bold
}

# Each limits block escalates on its own value; both rest on grey.
_seg_limits() {
    local h="${SL_5H%%.*}" w="${SL_WK%%.*}"
    if [ -n "$h" ]; then
        _thresh_color "$h" 70 90
        _fmt_rest "$SL_5H_RESET"
        local label="5h ${h}%"
        [ -n "$_REST" ] && label="$label · $_REST"
        _add "${ICON_5H}${label}" "$_COLOR"
    fi
    if [ -n "$w" ]; then
        _thresh_color "$w" 70 90
        _add "${ICON_WK}wk ${w}%" "$_COLOR"
    fi
}

_seg_cost() {
    [ -n "$SL_COST" ] || return 0
    local formatted
    printf -v formatted '$%.2f' "$SL_COST" 2>/dev/null || return 0
    _add "$formatted" "surface"
}

# --- full-width gradient -----------------------------------------------------

# Set _WIDTH to the display width (cells) of "$1": UTF-8 codepoints, not
# bytes — every icon and label this script emits is single-width, so
# codepoint count equals cell count. LC_ALL=C forces byte-wise indexing for
# the duration of this function regardless of the ambient locale or this
# bash's own multibyte awareness, so continuation bytes (the 0x80-0xBF range)
# can be counted and subtracted out: every codepoint has exactly one leading
# (non-continuation) byte. No subprocess.
_display_width() {
    local LC_ALL=C s="$1" i n=0
    local len=${#s}
    for ((i = 0; i < len; i++)); do
        case "${s:i:1}" in
            [$'\x80'-$'\xBF']) ;;
            *) n=$((n + 1)) ;;
        esac
    done
    _WIDTH=$n
}

# Parse "$1" as an "r;g;b" triplet of 0-255 integers into _R/_G/_B. Returns 1
# (leaving _R/_G/_B unset) if the string doesn't parse — a missing field, an
# extra field, a non-numeric value, and an out-of-range channel are all
# rejected by the same width/format check, so callers need no separate
# validation step: a failed parse is the single "this isn't usable" signal.
_parse_rgb_triplet() {
    local rgb="$1" r g b
    [[ "$rgb" =~ ^[0-9]{1,3}\;[0-9]{1,3}\;[0-9]{1,3}$ ]] || return 1
    IFS=';' read -r r g b <<< "$rgb"
    [ "$r" -le 255 ] && [ "$g" -le 255 ] && [ "$b" -le 255 ] || return 1
    _R="$r"; _G="$g"; _B="$b"
}

# Set _LC to the integer channel value at index $3 of $4 total steps, lerping
# from $1 to $2 (round-to-nearest). Bash's integer division truncates toward
# zero, which would bias every intermediate step toward $1 — the
# doubled-numerator trick corrects that without floats or a fork. i=0 hits $1
# exactly; i=steps-1 hits $2 exactly.
_lerp_channel() {
    local c0="$1" c1="$2" i="$3" steps="$4"
    local last=$((steps - 1))
    if [ "$last" -le 0 ]; then _LC="$c1"; return; fi
    local delta=$(( (c1 - c0) * i )) num den
    num=$((delta * 2)); den=$((last * 2))
    if [ "$delta" -ge 0 ]; then
        _LC=$(( c0 + (num + last) / den ))
    else
        _LC=$(( c0 + (num - last) / den ))
    fi
}

# Set _GRADIENT to "$3" background-only SGR cells fading from "$1" (an r;g;b
# triplet) to "$2". Empty (no cells) if either triplet fails to parse, so a
# caller can unconditionally append _GRADIENT with no separate validation
# gate. Fork-free: no command substitution beyond the here-string splits
# already used elsewhere in this script for delimited fields.
_build_gradient() {
    local src="$1" dst="$2" cells="$3"
    _GRADIENT=""
    _parse_rgb_triplet "$src" || return 0
    local sr="$_R" sg="$_G" sb="$_B"
    _parse_rgb_triplet "$dst" || return 0
    local dr="$_R" dg="$_G" db="$_B"
    local esc=$'\033' i r g b
    for ((i = 0; i < cells; i++)); do
        _lerp_channel "$sr" "$dr" "$i" "$cells"; r="$_LC"
        _lerp_channel "$sg" "$dg" "$i" "$cells"; g="$_LC"
        _lerp_channel "$sb" "$db" "$i" "$cells"; b="$_LC"
        _GRADIENT+="${esc}[48;2;${r};${g};${b}m "
    done
}

# Set _LUM to the BT.709 relative luminance of _R/_G/_B, scaled by 10000 (so
# the mid-grey pivot is 1275000). Reads the channels _parse_rgb_triplet leaves
# behind; fork-free.
_luminance() {
    _LUM=$((2126 * _R + 7152 * _G + 722 * _B))
}

# Set _R/_G/_B to a shade of the color "$1", nudged away from itself: darker
# when it is light, lighter when it is dark, classified by BT.709 luminance.
# Used both for the gauge surface (a shade of the terminal background) and for
# the divider sliver (a shade of the pill's own background). Returns non-zero
# on a color that does not parse, so callers can fall back.
_bg_shade() {
    _parse_rgb_triplet "$1" || return 1
    local r="$_R" g="$_G" b="$_B" shift=10
    _luminance
    if [ "$_LUM" -ge 1275000 ]; then
        _R=$((r * (100 - shift) / 100))
        _G=$((g * (100 - shift) / 100))
        _B=$((b * (100 - shift) / 100))
    else
        _R=$((r + (255 - r) * shift / 100))
        _G=$((g + (255 - g) * shift / 100))
        _B=$((b + (255 - b) * shift / 100))
    fi
}

# --- render ----------------------------------------------------------------

_render() {
    local n=${#_SEG_TEXT[@]}
    [ "$n" -gt 0 ] || return 0

    if [ "$LEVEL" = "plain" ]; then
        local i out=""
        for ((i = 0; i < n; i++)); do
            [ -n "$out" ] && out+=" > "
            out+="${_SEG_TEXT[i]}"
        done
        printf '%s\n' "$out"
        return 0
    fi

    # Squared pills that abut: each segment is a flat block with square edges,
    # and the divider between differing backgrounds is just the color change,
    # the most discreet separator there is. Same-background neighbors get a thin
    # one-eighth bar in a light warm grey so the boundary does not vanish.
    # Renders in any monospace font.
    local esc=$'\033' reset=$'\033[0m' thin=$'\xe2\x96\x8f'   # U+258F ▏
    # The divider ink colors are loop-invariant, so resolve them once: the
    # light warm grey for same-color pairs, and a darker coral for the logo's
    # boundary. A hairline reads as *thin* only because its cell background
    # matches a neighbor — U+258F inks just its left ~1/8, so the other ~7/8
    # must disappear into an adjacent pill or the whole one-column cell shows
    # as a solid block. Same-color pairs share a background, so their divider
    # cell takes that shared color; the logo boundary sits between two
    # differing colors, so its divider cell takes the NON-logo neighbor's
    # color (resolved per boundary, below), leaving only the thin ink sliver.
    _sgr 38 hairline; local hairfg="$_SGR"
    _sgr 38 brandshade; local logosepfg="$_SGR"

    # Lead with a reset so any residual SGR state from the caller's terminal
    # cannot bleed into the first segment's text.
    local i out="$reset" bg nbg bgsgr fgtext width=0 lastrgb="" sepbg lead same pulse
    for ((i = 0; i < n; i++)); do
        bg="${_SEG_BG[i]}"
        _sgr 48 "$bg"; bgsgr="$_SGR"; lastrgb="$_RGB"
        # Light backgrounds take dark text; accents take the usage chip's
        # text color, everything else plain white. SGR bold is stateful, so
        # every segment emits its intensity explicitly (1 accent, 22 normal)
        # or it would inherit bold from the accent before it.
        case "$bg" in
            amber|white) _sgr 38 black ;;
            surface)
                # Contrast against the resolved surface: dark text only on a
                # clearly light shade, light text otherwise. The pivot sits at
                # ~0.6 luminance (not 0.5) so the mid taupe greys of the
                # unknown-background fallback keep their light text; only the
                # genuinely light bg-derived surfaces flip to dark text.
                if [ "$LEVEL" = "truecolor" ] && _parse_rgb_triplet "$lastrgb" \
                    && { _luminance; [ "$_LUM" -ge 1530000 ]; }; then
                    # A heavily darkened shade of the surface: dark enough to
                    # read, but a warm tonal ink rather than a harsh near-black.
                    _SGR="38;2;$((_R * 35 / 100));$((_G * 35 / 100));$((_B * 35 / 100))"
                else
                    _sgr 38 white
                fi ;;
            *)
                # Claude Code's TUI re-emits only bold/fg/bg from the
                # statusline's ANSI, so terminal blink (SGR 5) never reaches
                # the screen. The attention pulse is software-driven instead:
                # the flagged mark alternates chiptext/brandshade by epoch-
                # second parity, and the statusLine registration's
                # refreshInterval repaints the bar every second while idle so
                # the phase keeps advancing. CS_STATUSLINE_NOW pins the clock
                # for tests.
                if [ "${_SEG_BOLD[i]}" = "boldattention" ]; then
                    _sl_now
                    pulse="${_NOW:-0}"
                    if [ $(( pulse % 2 )) -eq 1 ]; then _sgr 38 brandshade; else _sgr 38 chiptext; fi
                elif [ -n "${_SEG_BOLD[i]}" ]; then _sgr 38 chiptext; else _sgr 38 white; fi ;;
        esac
        fgtext="$_SGR"
        if [ -n "${_SEG_BOLD[i]}" ]; then fgtext+=";1"; else fgtext+=";22"; fi
        # A segment immediately after the logo inherits that boundary's divider
        # cell as its leading pad — the cell already carries this segment's
        # background — so it drops its own leading space to stay symmetric with
        # every other pill. The trailing space is always emitted.
        lead=" "
        [ "$i" -gt 0 ] && [ "${_SEG_BG[i - 1]}" = "brand" ] && lead=""
        out+="${esc}[${bgsgr};${fgtext}m${lead}${_SEG_TEXT[i]} "
        _display_width "${_SEG_TEXT[i]}"; width=$((width + 1 + ${#lead} + _WIDTH))
        if [ $((i + 1)) -lt "$n" ]; then
            nbg="${_SEG_BG[i + 1]}"
            if [ "$bg" = "brand" ] || [ "$nbg" = "brand" ]; then
                # The logo is a fixed brand mark, not part of the flowing
                # identity/gauge segments, so its boundary always shows a
                # divider: the same thin `▏` glyph every other divider uses,
                # inked in darker coral, on a background matching the non-logo
                # neighbor so the glyph's uninked ~7/8 merges into that pill
                # and only the thin sliver shows.
                if [ "$bg" = "brand" ]; then _sgr 48 "$nbg"; else _sgr 48 "$bg"; fi
                sepbg="$_SGR"
                out+="${esc}[${sepbg};${logosepfg}m${thin}"
                width=$((width + 1))
            else
                # Differing backgrounds abut; the color change is the divider.
                # Backgrounds that resolve to the SAME rendered color get a
                # thin bar in the light warm grey (lighter than the block,
                # softer than the white label) so the boundary does not
                # vanish. Comparing resolved RGB rather than color names is
                # what this needs: a `claude_session_color` of "orange"
                # renders identically to the logo's "brand" coral under a
                # different name, so a name-equality check would miss that
                # collision — moot here since the logo branch above already
                # covers every logo boundary, but the same principle applies
                # to any other pair of segments that might one day share an
                # RGB under different names.
                same=""
                if [ "$LEVEL" = "truecolor" ]; then
                    _sgr 48 "$nbg"; [ "$_RGB" = "$lastrgb" ] && same=1
                elif [ "$nbg" = "$bg" ]; then
                    same=1
                fi
                if [ -n "$same" ]; then
                    # Ink the sliver in a faint shade of the pill's own
                    # background so the separator reads as a tonal step rather
                    # than a foreign grey line — more discreet, and it follows
                    # whatever color the neighbors share. The warm grey stays as
                    # the fallback where there is no per-channel background.
                    local hairink="$hairfg"
                    if [ "$LEVEL" = "truecolor" ] && _bg_shade "$lastrgb"; then
                        hairink="38;2;${_R};${_G};${_B}"
                    fi
                    out+="${esc}[${bgsgr};${hairink}m${thin}"
                    width=$((width + 1))
                fi
            fi
        fi
    done
    # Stretch the bar to the full terminal width by fading the trailing edge
    # from the last pill's own background into the terminal's real background
    # color. Both pieces of information are prerequisites Claude Code and cs
    # may not provide: $COLUMNS is only set on Claude Code >= 2.1.153, and
    # CS_TERM_BG_RGB is only known when cs's own OSC 11 query succeeded at
    # launch. Truecolor-only — 256-color/basic modes don't have the per-channel
    # precision for a gradient to look like anything but banding.
    if [ "$LEVEL" = "truecolor" ] && [ -n "$lastrgb" ] \
        && [[ "${COLUMNS:-}" =~ ^[0-9]+$ ]] && [ "$COLUMNS" -ge 1 ] && [ "$COLUMNS" -le 2000 ]; then
        local remaining=$((COLUMNS - width))
        # Bounded independent of $COLUMNS itself: defense in depth for a loop
        # that runs on every render.
        [ "$remaining" -gt 500 ] && remaining=500
        if [ "$remaining" -gt 0 ]; then
            _build_gradient "$lastrgb" "${CS_TERM_BG_RGB:-}" "$remaining"
            out+="$_GRADIENT"
        fi
    fi
    out+="$reset"
    printf '%s\n' "$out"
}

# --- main ------------------------------------------------------------------

main() {
    [ "${CS_STATUSLINE_DISABLE:-}" = "1" ] && exit 0

    # Sanitize the shared-clock memo at the start of every render: neither the
    # value nor its ready flag may be seeded by an inherited environment variable
    # of the same name. Otherwise a stale/garbage _NOW would poison the limits
    # stamp and crash the pulse arithmetic (bash 3.2 set -u). Free, no fork.
    _NOW=""
    _SL_NOW_READY=""

    _read_stdin
    _parse_stdin "$_STDIN" || _fallback

    _detect_level

    local segments="${CS_STATUSLINE_SEGMENTS:-logo,session,notes,pane,git,model,ctx,limits,cost}"
    local name names
    IFS=',' read -ra names <<< "$segments"
    for name in "${names[@]}"; do
        case "$name" in
            logo)    _seg_logo ;;
            session) _seg_session ;;
            notes)   _seg_notes ;;
            pane)    _seg_pane ;;
            ctx)     _seg_ctx ;;
            model)   _seg_model ;;
            git)     _seg_git ;;
            limits)  _seg_limits ;;
            cost)    _seg_cost ;;
        esac
    done

    _render
}

# Sourced with CS_STATUSLINE_LIB=1, this file is a library: the palette, color
# ladder, and width helpers load without rendering. `return` is not usable here
# because it is an error outside a function in an executed script.
[ "${CS_STATUSLINE_LIB:-}" = "1" ] || main "$@"
