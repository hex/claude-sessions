#!/usr/bin/env bash
# ABOUTME: Claude Code statusLine command — renders a one-line powerline status bar
# ABOUTME: Reads the statusline JSON on stdin and prints session/ctx/model/git/limits/cost

set -uo pipefail

SESSIONS_ROOT="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"

# Read-only status query; never take the index lock from a render.
export GIT_OPTIONAL_LOCKS=0

# Terminal theme, exported by cs at launch (detected via COLORFGBG/OSC 11
# while cs still owned the tty). Anything but "dark" renders the light set.
SL_THEME="${CS_TERM_THEME:-light}"

# Parsed stdin fields (filled by _parse_stdin).
SL_SESSION=""; SL_CTX=""; SL_MODEL=""; SL_EFFORT=""
SL_5H=""; SL_WK=""; SL_COST=""; SL_DIR=""

# Collected segments (parallel arrays) and chosen color level.
_SEG_TEXT=(); _SEG_BG=(); _SEG_BOLD=(); LEVEL="basic"

# Scratch globals used in place of command substitution (keeps the per-render
# hot path fork-free; this script runs on every assistant message).
_SGR=""; _COLOR=""

# Per-segment icons. Standard Unicode (Geometric Shapes + dingbats) that render
# in any monospace font — not Nerd Font private-use glyphs — so the bar looks
# right without a patched font. CS_NERD_FONTS only upgrades the segment
# separators to the powerline arrow (see _render); the icons are unaffected.
ICON_SESSION=$'\xe2\xac\xa3 '   # U+2B23 horizontal hexagon
ICON_CTX=$'\xe2\x97\x94 '       # U+25D4 quadrant circle (gauge)
ICON_MODEL=$'\xe2\x9c\xa6 '     # U+2726 four-pointed star
ICON_GIT=$'\xe2\x8e\x87 '       # U+2387 branch
ICON_5H=$'\xe2\x97\xb7 '        # U+25F7 clock
ICON_WK=$'\xe2\x97\x91 '        # U+25D1 half circle

# --- stdin -----------------------------------------------------------------

# Run a command with a wall-clock cap when timeout(1) is available, else plain.
_timeout() {
    local secs="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$secs" "$@"
    else
        "$@"
    fi
}

# Slurp stdin into _STDIN with a builtin read so no subprocess is spawned and
# a stuck pipe cannot hang the render past one second. Handles single-line
# compact JSON (the common case) and multi-line pretty JSON alike.
_read_stdin() {
    _STDIN=""
    [ -t 0 ] && return 0
    local line=""
    while IFS= read -r -t 1 line; do
        _STDIN+="$line"$'\n'
    done
    _STDIN+="$line"   # trailing partial line (no newline) or empty
}

# Extract every field we need in one jq pass, one value per line. Returns
# non-zero (caller falls back) when jq is missing, stdin is empty, or the JSON
# does not parse. One value per line (not @tsv) because `read` collapses
# consecutive tab delimiters, which would drop empty fields and shift values.
_parse_stdin() {
    local input="$1" fields
    command -v jq >/dev/null 2>&1 || return 1
    [ -n "$input" ] || return 1
    fields=$(printf '%s' "$input" | jq -r '
        [ (.session_name // ""),
          (.context_window.used_percentage // "" | tostring),
          (.model.display_name // ""),
          (.effort.level // ""),
          (.rate_limits.five_hour.used_percentage // "" | tostring),
          (.rate_limits.seven_day.used_percentage // "" | tostring),
          (.cost.total_cost_usd // "" | tostring),
          (.workspace.current_dir // .cwd // "")
        ] | .[]' 2>/dev/null) || return 1
    {
        IFS= read -r SL_SESSION
        IFS= read -r SL_CTX
        IFS= read -r SL_MODEL
        IFS= read -r SL_EFFORT
        IFS= read -r SL_5H
        IFS= read -r SL_WK
        IFS= read -r SL_COST
        IFS= read -r SL_DIR
    } <<EOF
$fields
EOF
    return 0
}

# Print the dir basename as a last-resort plain status, then exit cleanly.
_fallback() {
    printf '%s\n' "$(basename "${PWD:-/}")"
    exit 0
}

# --- color ladder ----------------------------------------------------------

# Choose the richest color level the terminal advertises.
_detect_level() {
    if [ "${FORCE_COLOR:-}" = "0" ] || [ -n "${NO_COLOR:-}" ] || [ "${TERM:-}" = "dumb" ]; then
        LEVEL="plain"
    elif [ "${COLORTERM:-}" = "truecolor" ] || [ "${COLORTERM:-}" = "24bit" ] \
        || [ "${TERM_PROGRAM:-}" = "iTerm.app" ] || [ "${TERM_PROGRAM:-}" = "WezTerm" ]; then
        LEVEL="truecolor"
    elif [[ "${TERM:-}" == *256color* ]]; then
        LEVEL="256"
    else
        LEVEL="basic"
    fi
}

# Set _SGR to the SGR parameters painting a color name for the active level.
# $1 = 38 (foreground) or 48 (background); $2 = color name. No subprocess.
_sgr() {
    local kind="$1" name="$2"
    case "$LEVEL" in
        truecolor)
            local rgb
            case "$name" in
                # Session-color palette: tuned dark enough for white text.
                # KEEP IN SYNC with _session_color_rgb in bin/cs (tab color).
                red)    rgb="211;47;47" ;;
                blue)   rgb="30;107;200" ;;
                green)  rgb="46;125;50" ;;
                yellow) rgb="154;120;20" ;;
                purple) rgb="126;87;194" ;;
                orange) rgb="216;107;28" ;;
                pink)   rgb="194;58;130" ;;
                cyan)   rgb="0;131;143" ;;
                periwinkle) rgb="153;152;255" ;;
                chiptext) rgb="240;242;255" ;;
                amber)  rgb="255;183;77" ;;
                white)
                    # Softer text on dark terminals to avoid glare.
                    [ "$SL_THEME" = "dark" ] && rgb="230;230;230" || rgb="255;255;255" ;;
                black)  rgb="30;30;30" ;;
                *)
                    # Neutral lifts on dark terminals to separate from the bg.
                    [ "$SL_THEME" = "dark" ] && rgb="100;100;108" || rgb="88;88;88" ;;
            esac
            _SGR="${kind};2;${rgb}" ;;
        256)
            local idx
            case "$name" in
                red)    idx=160 ;;
                blue)   idx=25 ;;
                green)  idx=28 ;;
                yellow) idx=136 ;;
                purple) idx=55 ;;
                orange) idx=166 ;;
                pink)   idx=162 ;;
                cyan)   idx=30 ;;
                periwinkle) idx=105 ;;
                chiptext) idx=231 ;;
                amber)  idx=215 ;;
                white)
                    [ "$SL_THEME" = "dark" ] && idx=254 || idx=255 ;;
                black)  idx=235 ;;
                *)
                    [ "$SL_THEME" = "dark" ] && idx=242 || idx=240 ;;
            esac
            _SGR="${kind};5;${idx}" ;;
        *)
            local base
            case "$name" in
                red)    base=31 ;;
                blue)   base=34 ;;
                green)  base=32 ;;
                yellow) base=33 ;;
                purple) base=35 ;;
                orange) base=33 ;;
                pink)   base=95 ;;
                cyan)   base=36 ;;
                periwinkle) base=94 ;;
                chiptext) base=97 ;;
                amber)  base=33 ;;
                white)  base=97 ;;
                black)  base=30 ;;
                *)      base=90 ;;
            esac
            if [ "$kind" = "48" ]; then _SGR=$((base + 10)); else _SGR="$base"; fi ;;
    esac
}

# --- segment helpers -------------------------------------------------------

# Append a segment (text + background color name).
_add() {
    _SEG_TEXT+=("$1")
    _SEG_BG+=("$2")
    _SEG_BOLD+=("${3:-}")
}

# Set _COLOR by mapping a value against warn/crit thresholds; below warn it
# takes the healthy color ($4, default grey).
_thresh_color() {
    local v="$1" warn="$2" crit="$3" healthy="${4:-grey}"
    if [ "$v" -ge "$crit" ]; then
        _COLOR=red
    elif [ "$v" -ge "$warn" ]; then
        _COLOR=amber
    else
        _COLOR="$healthy"
    fi
}

# Read claude_session_color from a session README's frontmatter into
# _SESSION_COLOR (empty if none). Pure bash: this runs once per render, where
# an awk fork is real cost. KEEP THE FRONTMATTER FORMAT IN SYNC WITH bin/cs's
# _read_session_color.
_read_session_color() {
    _SESSION_COLOR=""
    local readme="$1" line v
    [ -f "$readme" ] || return 0
    while IFS= read -r line; do
        case "$line" in
            claude_session_color:*)
                v="${line#claude_session_color:}"
                v="${v#"${v%%[![:space:]]*}"}"
                _SESSION_COLOR="${v//\"/}"
                return 0
                ;;
        esac
    done < "$readme"
}

# Byte size of a file into _FILESIZE (0 on failure); arithmetic evaluation
# strips wc's leading whitespace without a tr fork, and an empty result
# evaluates to 0 instead of erroring.
_filesize() {
    local n
    n=$(wc -c < "$1" 2>/dev/null) || n=0
    _FILESIZE=$(( n ))
}

# Format the git segment text for a workspace dir into _GIT_TEXT, empty when
# it is not a git repo / git is unavailable / git times out.
_git_text() {
    _GIT_TEXT=""
    local dir="$1"
    [ -n "$dir" ] || return 0
    [ -e "$dir/.git" ] || return 0
    local out
    out=$(_timeout 2 git -C "$dir" status --porcelain=v1 -b 2>/dev/null) || return 0
    local branch="" ahead=0 behind=0 staged=0 modified=0 first=1 line x y h
    while IFS= read -r line; do
        if [ "$first" = "1" ]; then
            first=0
            h="${line#\#\# }"
            case "$h" in
                "No commits yet on "*) branch="${h#No commits yet on }" ;;
                "HEAD (no branch)")    branch="HEAD" ;;
                *)
                    branch="${h%%...*}"
                    [[ "$h" =~ ahead\ ([0-9]+) ]] && ahead="${BASH_REMATCH[1]}"
                    [[ "$h" =~ behind\ ([0-9]+) ]] && behind="${BASH_REMATCH[1]}"
                    ;;
            esac
        else
            x="${line:0:1}"; y="${line:1:1}"
            # Untracked entries are `??` in both columns; exclude `?` from both
            # counts so untracked files do not show as a phantom modified `!`.
            [ "$x" != " " ] && [ "$x" != "?" ] && staged=$((staged + 1))
            [ "$y" != " " ] && [ "$y" != "?" ] && modified=$((modified + 1))
        fi
    done <<EOF
$out
EOF
    [ -n "$branch" ] || return 0
    local text="$branch"
    # Brace the expansion: a bare $text↑ would let set -u read the arrow's first
    # UTF-8 byte as part of the variable name and abort on "unbound variable".
    [ "$ahead" -gt 0 ] && text="${text}↑${ahead}"
    [ "$behind" -gt 0 ] && text="${text}↓${behind}"
    local marks=""
    [ "$staged" -gt 0 ] && marks="+$staged"
    [ "$modified" -gt 0 ] && marks="$marks!$modified"
    [ -n "$marks" ] && text="$text $marks"
    _GIT_TEXT="$text"
}

# --- segments --------------------------------------------------------------

_seg_session() {
    local name="$SL_SESSION"
    [ -n "$name" ] || name="${CLAUDE_SESSION_NAME:-}"
    if [ -z "$name" ]; then
        local dir="${SL_DIR:-$PWD}"
        name="${dir##*/}"
    fi
    local bg="grey" color=""
    if [ -n "${CLAUDE_SESSION_NAME:-}" ]; then
        _read_session_color "$SESSIONS_ROOT/$CLAUDE_SESSION_NAME/.cs/README.md"
        color="$_SESSION_COLOR"
        [ -n "$color" ] && bg="$color"
    fi
    _add "${ICON_SESSION}${name}" "$bg" bold
}

_seg_ctx() {
    local v="${SL_CTX%%.*}"
    [ -n "$v" ] || return 0
    local warn="${CS_STATUSLINE_CTX_WARN:-50}" crit="${CS_STATUSLINE_CTX_CRIT:-80}"
    _thresh_color "$v" "$warn" "$crit"
    _add "${ICON_CTX}ctx ${v}%" "$_COLOR"
}

_seg_model() {
    [ -n "$SL_MODEL" ] || return 0
    local t="$SL_MODEL"
    [ -n "$SL_EFFORT" ] && t="$t $SL_EFFORT"
    _add "${ICON_MODEL}${t}" "periwinkle" bold
}

_seg_git() {
    _git_text "$SL_DIR"
    local t="$_GIT_TEXT"
    [ -n "$t" ] || return 0
    _add "${ICON_GIT}${t}" "grey"
}

# Each limits block escalates on its own value; both rest on grey.
_seg_limits() {
    local h="${SL_5H%%.*}" w="${SL_WK%%.*}"
    if [ -n "$h" ]; then
        _thresh_color "$h" 70 90
        _add "${ICON_5H}5h ${h}%" "$_COLOR"
    fi
    if [ -n "$w" ]; then
        _thresh_color "$w" 70 90
        _add "${ICON_WK}wk ${w}%" "$_COLOR"
    fi
}

_seg_cost() {
    [ -n "$SL_COST" ] || return 0
    local formatted
    printf -v formatted '$%.2f' "$SL_COST" 2>/dev/null || return 0
    _add "$formatted" "grey"
}

# --- render ----------------------------------------------------------------

_render() {
    local n=${#_SEG_TEXT[@]}
    [ "$n" -gt 0 ] || return 0

    if [ "$LEVEL" = "plain" ]; then
        local i out=""
        for ((i = 0; i < n; i++)); do
            [ -n "$out" ] && out+=" > "
            out+="${_SEG_TEXT[i]}"
        done
        printf '%s\n' "$out"
        return 0
    fi

    local esc=$'\033' reset=$'\033[0m' glyph=">" thin="›"
    if [ "${CS_NERD_FONTS:-}" = "1" ]; then
        glyph=$'\xee\x82\xb0'   # U+E0B0 solid arrow
        thin=$'\xee\x82\xb1'    # U+E0B1 outline chevron
    fi

    # Lead with a reset so any residual SGR state from the caller's terminal
    # cannot bleed into the first segment's text.
    local i out="$reset" bg nbg bgsgr fgtext fgseg nbgsgr
    for ((i = 0; i < n; i++)); do
        bg="${_SEG_BG[i]}"
        _sgr 48 "$bg"; bgsgr="$_SGR"
        # Light backgrounds take dark text; accents take the usage chip's
        # text color, everything else plain white. SGR bold is stateful, so
        # every segment emits its intensity explicitly (1 accent, 22 normal)
        # or it would inherit bold from the accent before it.
        case "$bg" in
            amber|white) _sgr 38 black ;;
            *)
                if [ -n "${_SEG_BOLD[i]}" ]; then _sgr 38 chiptext; else _sgr 38 white; fi ;;
        esac
        fgtext="$_SGR"
        if [ -n "${_SEG_BOLD[i]}" ]; then fgtext+=";1"; else fgtext+=";22"; fi
        out+="${esc}[${bgsgr};${fgtext}m ${_SEG_TEXT[i]} "
        _sgr 38 "$bg"; fgseg="$_SGR"
        if [ $((i + 1)) -lt "$n" ]; then
            nbg="${_SEG_BG[i + 1]}"
            if [ "$nbg" = "$bg" ]; then
                # A solid arrow vanishes between equal backgrounds; draw a thin
                # chevron in the segment's text color to keep the boundary.
                out+="${esc}[${bgsgr};${fgtext}m${thin}"
            else
                _sgr 48 "$nbg"; nbgsgr="$_SGR"
                out+="${esc}[22;${fgseg};${nbgsgr}m${glyph}"
            fi
        else
            out+="${reset}${esc}[${fgseg}m${glyph}${reset}"
        fi
    done
    printf '%s\n' "$out"
}

# --- main ------------------------------------------------------------------

main() {
    [ "${CS_STATUSLINE_DISABLE:-}" = "1" ] && exit 0

    _read_stdin
    _parse_stdin "$_STDIN" || _fallback

    _detect_level

    local segments="${CS_STATUSLINE_SEGMENTS:-session,model,ctx,git,limits,cost}"
    local name names
    IFS=',' read -ra names <<< "$segments"
    for name in "${names[@]}"; do
        case "$name" in
            session) _seg_session ;;
            ctx)     _seg_ctx ;;
            model)   _seg_model ;;
            git)     _seg_git ;;
            limits)  _seg_limits ;;
            cost)    _seg_cost ;;
        esac
    done

    _render
}

main "$@"
