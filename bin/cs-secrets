#!/usr/bin/env bash
# ABOUTME: Cross-platform secure secrets management for cs sessions
# ABOUTME: Supports macOS Keychain, Windows Credential Manager (PowerShell), and encrypted-file/age fallback

set -euo pipefail

SCRIPT_NAME=$(basename "$0")

# Configuration
SECRETS_DIR="${HOME}/.cs-secrets"
SALT_FILE="${SECRETS_DIR}/.salt"

# KEEP IN SYNC with lib/02-platform.sh
# Returns one of: macos | wsl | msys | linux   (cached after first detect)
cs_platform() {
    # Test/override seam: FIRST branch, validated, cache-bypassing.
    if [ -n "${CS_PLATFORM_OVERRIDE:-}" ]; then
        case "$CS_PLATFORM_OVERRIDE" in
            macos|wsl|msys|linux) printf '%s' "$CS_PLATFORM_OVERRIDE"; return 0 ;;
            *) printf 'cs: invalid CS_PLATFORM_OVERRIDE: %s\n' "$CS_PLATFORM_OVERRIDE" >&2; return 1 ;;
        esac
    fi
    [ -n "${_CS_PLATFORM:-}" ] && { printf '%s' "$_CS_PLATFORM"; return 0; }
    local p
    case "$(uname -s 2>/dev/null)" in
        Darwin) p=macos ;;
        MINGW*|MSYS*|CYGWIN*) p=msys ;;
        Linux)
            if [ -n "${WSL_DISTRO_NAME:-}" ] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
                p=wsl
            else
                p=linux
            fi ;;
        *) p=linux ;;
    esac
    _CS_PLATFORM="$p"; printf '%s' "$p"
}

usage() {
    cat <<EOF
Usage: $SCRIPT_NAME <command> [options]

Commands:
    set, store <name> [val] Store a secret (prompts if value not provided)
    get <name>              Retrieve a secret value
    list, ls                List all secrets for current session
    delete, rm <name>       Delete a secret
    purge                   Delete ALL secrets for current session
    export                  Export secrets as environment variables (eval-able)
    export-file [FILE]      Export secrets to encrypted file for sync
    import-file [FILE]      Import secrets from encrypted file
    migrate [--redact]      Migrate plaintext secrets from artifact files
    migrate-backend <to>    Migrate secrets to different backend [--from <backend>] [--delete-source]
    backend                 Show which storage backend is being used

Age Commands (public-key encryption for sync):
    age init                Initialize age keypair (auto-downloads age if needed)
    age pubkey              Print your public key for sharing
    age add <file|key>      Add a recipient public key to current session
    age list                List recipients who can decrypt session secrets
    age remove <name>       Remove a recipient from session

Options:
    -s, --session <name>    Specify session (default: \$CLAUDE_SESSION_NAME;
                            interactive terminals are offered a session picker)
    -h, --help              Show this help message

Backends (auto-detected, in priority order):
    keychain    macOS Keychain (most secure on macOS)
    encrypted   OpenSSL-encrypted file (cross-platform fallback)

Sync formats (for export-file/import-file):
    age         Public-key encryption (preferred, no shared password)
    enc         AES-256-CBC with shared password (legacy, requires CS_SECRETS_PASSWORD)

Environment:
    CS_SECRETS_BACKEND      Override backend (keychain, encrypted)
    CS_SECRETS_PASSWORD     Master password for encrypted backend (legacy sync)
    CLAUDE_SESSION_NAME     Current session name
    CS_ASSUME_TTY           Treat the terminal as interactive for the session picker

Examples:
    $SCRIPT_NAME store api_key              # Prompts for value (interactive)
    printf '%s' "sk-abc123" | $SCRIPT_NAME store api_key  # From stdin, not argv
    $SCRIPT_NAME get api_key                # Retrieve value
    $SCRIPT_NAME list                       # List all secrets
    eval "\$($SCRIPT_NAME export)"          # Load secrets as env vars
    $SCRIPT_NAME age init                   # Set up age encryption
    $SCRIPT_NAME age pubkey                 # Get your public key
EOF
    exit 0
}

error() {
    echo "Error: $1" >&2
    exit 1
}

# Exit/return code a backend get uses for a genuinely-absent secret, distinct
# from a real read failure so callers (e.g. the merge-import existence probe)
# never mistake a transient backend error for "missing".
# KEEP IN SYNC with wcm_get and the .ps1 helper's `exit 3`.
readonly CS_NOT_FOUND=3

secrets_interactive() {
    [[ -t 0 || "${CS_ASSUME_TTY:-}" == "1" ]]
}

# Interactive session picker: numbered list on stderr, choice read from
# stdin. Sets SESSION_NAME on a valid selection; leaves it empty on abort,
# invalid input, or an empty sessions root. stdout never carries picker
# text, so $(cs-secrets get ...) command substitution stays clean.
prompt_session_choice() {
    local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
    local names=() d name
    for d in "$sessions_root"/*/; do
        [[ -d "${d}.cs" ]] || continue
        name=$(basename "$d")
        [[ "$name" == *@* ]] && continue
        [[ -f "${d}.cs/archived" ]] && continue
        names+=("$name")
    done
    # A working directory under the sessions root supplies the default; a
    # worktree dir (<base>@<task>) defaults to its base, which owns the
    # secrets namespace. Archived sessions qualify as defaults even though
    # the list hides them.
    local default_name="" real_pwd="" real_root=""
    real_pwd=$(pwd -P)
    real_root=$(cd "$sessions_root" 2>/dev/null && pwd -P) || real_root=""
    if [[ -n "$real_root" && "$real_pwd" == "$real_root"/* ]]; then
        default_name="${real_pwd#"$real_root"/}"
        default_name="${default_name%%/*}"
        default_name="${default_name%%@*}"
        [[ -d "$sessions_root/$default_name/.cs" ]] || default_name=""
    fi

    if [[ ${#names[@]} -eq 0 && -z "$default_name" ]]; then
        return 0
    fi

    {
        printf 'No session specified. Pick one:\n'
        if [[ ${#names[@]} -gt 0 ]]; then
            local i=1
            for name in "${names[@]}"; do
                printf '  %d) %s\n' "$i" "$name"
                i=$((i + 1))
            done
        fi
        if [[ -n "$default_name" ]]; then
            printf 'Session number [%s]: ' "$default_name"
        else
            printf 'Session number: '
        fi
    } >&2

    local choice=""
    if ! IFS= read -r choice; then
        return 0
    fi
    if [[ -z "$choice" && -n "$default_name" ]]; then
        SESSION_NAME="$default_name"
    elif [[ "$choice" =~ ^[0-9]{1,4}$ ]] \
        && (( 10#$choice >= 1 && 10#$choice <= ${#names[@]} )); then
        SESSION_NAME="${names[$((10#$choice - 1))]}"
    fi
    return 0
}

require_session() {
    if [[ -z "$SESSION_NAME" ]] && secrets_interactive; then
        prompt_session_choice
    fi
    if [[ -z "$SESSION_NAME" ]]; then
        error "No session specified. Set CLAUDE_SESSION_NAME or use --session"
    fi
}

# Detect operating system and available backend
detect_backend() {
    # Allow explicit override via environment variable
    if [[ -n "${CS_SECRETS_BACKEND:-}" ]]; then
        echo "$CS_SECRETS_BACKEND"
        return
    fi

    case "$(cs_platform)" in
        macos)
            if command -v security >/dev/null 2>&1; then
                echo "keychain"
                return
            fi
            ;;
        msys)
            # Windows Credential Manager via PowerShell, when available.
            if command -v powershell.exe >/dev/null 2>&1; then
                echo "wcm"
                return
            fi
            ;;
        # wsl/linux: no OS keystore by default -> encrypted below
    esac

    # Fallback to encrypted file (works everywhere with OpenSSL)
    if command -v openssl >/dev/null 2>&1; then
        echo "encrypted"
        return
    fi

    error "No supported secret storage backend found. Install OpenSSL for encrypted file support."
}

BACKEND=$(detect_backend)

# ============================================================================
# KEYCHAIN BACKEND (macOS)
# ============================================================================

keychain_service() {
    local session="$1"
    local name="$2"
    echo "cs:${session}:${name}"
}

# The account name Keychain items are filed under. USER is unset under Git Bash
# (it exports USERNAME), and a bare ${USER} would abort the whole expansion
# under `set -u` before `security` ever runs -- which callers cannot distinguish
# from a genuine backend read failure.
keychain_user() {
    local user
    user="${USER:-${USERNAME:-}}"
    [ -n "$user" ] || user=$(id -un 2>/dev/null) || user=""
    printf '%s' "${user:-unknown}"
}

keychain_store() {
    local session="$1"
    local name="$2"
    local value="$3"
    local service
    service=$(keychain_service "$session" "$name")

    security add-generic-password -a "$(keychain_user)" -s "$service" -w "$value" -U 2>/dev/null || \
        error "Failed to store secret in Keychain"
    echo "Stored secret: $name"
}

keychain_get() {
    local session="$1"
    local name="$2"
    local service
    service=$(keychain_service "$session" "$name")

    # `security find-generic-password` exits 44 (errSecItemNotFound) when the
    # item is genuinely absent; any other nonzero is a real read failure. Map
    # absent to CS_NOT_FOUND and propagate everything else so callers don't
    # treat a transient Keychain error as "missing".
    local value rc=0
    value=$(security find-generic-password -a "$(keychain_user)" -s "$service" -w 2>/dev/null) || rc=$?
    if [[ $rc -eq 0 ]]; then
        echo "$value"
    elif [[ $rc -eq 44 ]]; then
        echo "Error: secret not found: $name" >&2
        return "$CS_NOT_FOUND"
    else
        echo "Error: failed to read secret from Keychain: $name" >&2
        return "$rc"
    fi
}

# Extract stored secret names for a session from a `security dump-keychain`
# blob, one per line. Returns 0 for matches OR a genuinely empty store (grep
# exit 1 = no match); returns nonzero on a real grep error (exit >1) or a sed
# failure, which callers MUST NOT swallow into "no secrets".
keychain_extract_names() {
    local dump="$1" session="$2"
    local matched grc=0
    matched=$(printf '%s\n' "$dump" | grep -o "\"svce\"<blob>=\"cs:${session}:[^\"]*\"") || grc=$?
    [[ $grc -gt 1 ]] && return 1
    [[ -z "$matched" ]] && return 0
    printf '%s\n' "$matched" | sed "s/\"svce\"<blob>=\"cs:${session}://;s/\"$//"
}

keychain_list() {
    local session="$1"

    # Distinguish a real `security` enumeration failure from an empty store:
    # capture the dump and check its exit before filtering (grep no-match =
    # empty store, not a failure).
    local dump
    if ! dump=$(security dump-keychain 2>/dev/null); then
        error "Failed to enumerate Keychain for session: $session"
    fi
    local secrets
    secrets=$(keychain_extract_names "$dump" "$session") \
        || error "Failed to enumerate Keychain for session: $session"

    if [[ -z "$secrets" ]]; then
        echo "No secrets stored for session: $session"
    else
        echo "Secrets for session: $session"
        printf '%s\n' "$secrets" | while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            echo "  - $name"
        done
    fi
}

keychain_delete() {
    local session="$1"
    local name="$2"
    local service
    service=$(keychain_service "$session" "$name")

    if security delete-generic-password -a "$(keychain_user)" -s "$service" >/dev/null 2>&1; then
        echo "Deleted secret: $name"
    else
        error "Secret not found or could not be deleted: $name"
    fi
}

keychain_purge() {
    local session="$1"
    local dump
    if ! dump=$(security dump-keychain 2>/dev/null); then
        error "Failed to enumerate Keychain for session: $session"
    fi
    local secrets
    secrets=$(keychain_extract_names "$dump" "$session") \
        || error "Failed to enumerate Keychain for session: $session"

    if [[ -z "$secrets" ]]; then
        echo "No secrets to purge for session: $session"
        return 0
    fi

    local count=0 failed=0 name service
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        service=$(keychain_service "$session" "$name")
        if security delete-generic-password -a "$(keychain_user)" -s "$service" >/dev/null 2>&1; then
            count=$((count + 1))
        else
            failed=$((failed + 1))
        fi
    done <<< "$secrets"

    # A partial purge is a failure, not a smaller count.
    if [[ $failed -gt 0 ]]; then
        echo "Error: purged $count secret(s), but $failed delete(s) failed for session: $session" >&2
        return 1
    fi

    echo "Purged $count secret(s) for session: $session"
}

keychain_export() {
    local session="$1"
    local dump
    if ! dump=$(security dump-keychain 2>/dev/null); then
        error "Failed to enumerate Keychain for session: $session"
    fi
    local secrets
    secrets=$(keychain_extract_names "$dump" "$session") \
        || error "Failed to enumerate Keychain for session: $session"
    [[ -z "$secrets" ]] && return 0

    # Buffer and emit only if EVERY listed credential reads; a per-item read
    # failure aborts nonzero rather than emitting a partial export the caller
    # would eval as the complete set. (Uses a here-string, not a `|`-subshell,
    # so `return` propagates out of the loop.)
    local name service value var_name out=""
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        service=$(keychain_service "$session" "$name")
        if value=$(security find-generic-password -a "$(keychain_user)" -s "$service" -w 2>/dev/null); then
            valid_secret_name "$name" \
                || error "Refusing to export session '$session': stored secret name '$name' is not a valid identifier and would execute when this output is eval'd. Remove it with: cs -secrets delete '$name'"
            var_name=$(echo "$name" | tr '[:lower:]-' '[:upper:]_')
            out+=$(printf 'export %s=%q' "$var_name" "$value")$'\n'
        else
            echo "Error: failed to read Keychain secret: $name" >&2
            return 1
        fi
    done <<< "$secrets"

    printf '%s' "$out"
}

# ============================================================================
# ENCRYPTED FILE BACKEND (Cross-platform)
# ============================================================================

get_encryption_password() {
    # Priority:
    # 1. Environment variable
    # 2. Derived from machine characteristics + salt

    if [[ -n "${CS_SECRETS_PASSWORD:-}" ]]; then
        echo "$CS_SECRETS_PASSWORD"
        return
    fi

    # Ensure secrets directory and salt exist
    mkdir -p "$SECRETS_DIR"
    chmod 700 "$SECRETS_DIR"

    if [[ ! -f "$SALT_FILE" ]]; then
        # Publish the first-use salt atomically. The naive `openssl rand >
        # SALT_FILE` opens the file EMPTY before openssl fills it, so a
        # concurrent reader can derive its key from an empty salt and write a
        # store that is then permanently undecryptable; two first-use writers
        # could also each persist a different salt. Generate into a temp file,
        # then hard-link it into place: link() fails atomically if the salt
        # already exists (exactly one writer wins), and the salt path transitions
        # from absent to fully-written in one step — never observed half-written.
        # The loser and every later reader read the winner's complete salt below.
        local salt_tmp
        salt_tmp=$(mktemp "${SECRETS_DIR}/.salt.XXXXXX") \
            || error "Failed to create temp file for salt in: $SECRETS_DIR"
        if ! openssl rand -hex 32 > "$salt_tmp"; then
            rm -f "$salt_tmp"
            error "Failed to generate encryption salt"
        fi
        chmod 600 "$salt_tmp"
        ln "$salt_tmp" "$SALT_FILE" 2>/dev/null || true
        rm -f "$salt_tmp"
    fi

    if [[ ! -f "$SALT_FILE" ]]; then
        error "Encryption salt missing after creation attempt: $SALT_FILE"
    fi

    local salt
    salt=$(cat "$SALT_FILE")

    # Derive password from user + hostname + salt
    # This provides machine-specific encryption. USER is unset under Git Bash
    # (it exports USERNAME), and a bare ${USER} would abort here under `set -u`.
    # `-` rather than `:-` on purpose: an exported-but-empty USER must keep
    # deriving the password it always did, or that store stops opening. (The
    # sync-filename id uses `:-` instead, where an empty component is the bug.)
    # Windows hostname implementations differ in whether they emit a trailing
    # CR; strip it so the same box derives one password from any shell.
    local host
    host=$(hostname 2>/dev/null) || host=""
    host=${host//$'\r'/}
    local machine_id="${USER-${USERNAME-}}@${host}"
    echo -n "${machine_id}${salt}" | openssl dgst -sha256 -r | cut -d' ' -f1
}

# Every key of the JSON object on stdin, one per line, CR-free. jq.exe on
# Windows opens stdout in text mode and emits CRLF; a command substitution
# strips only the trailing newline, so every key but the LAST would otherwise
# reach a backend carrying a trailing CR -- storing ghosts that no `get` can
# ever name, while the final key looks perfectly healthy.
json_keys() {
    local keys
    keys=$(jq -r 'keys[]') || return 1
    printf '%s' "${keys//$'\r'/}"
}

# The value at $1 of the JSON object on stdin, byte-exact; empty when absent.
# Routed through base64 because jq.exe emits CRLF: a multi-line secret read as
# raw text gains a CR at every interior newline, and unlike a key those cannot
# be stripped -- a secret may legitimately contain one. Base64 is a single
# line, so the only newline is the trailing one a substitution already drops.
# The `// ""` is load-bearing: `null | @base64` encodes the STRING "null".
# A secret name becomes a shell variable name in the eval'd `export` output, so
# it must be an identifier and nothing else. Anything looser lets a name carry
# shell metacharacters that break out of the assignment and execute -- and sync
# files are meant to be committed and shared, so in the worst case the name is
# attacker-controlled. Hyphens are allowed because export maps them to
# underscores.
valid_secret_name() {
    case "$1" in
        ""|*[!A-Za-z0-9_-]*) return 1 ;;
        [!A-Za-z_]*)         return 1 ;;
    esac

    # Shape is not enough. `export` upper-cases the name and maps hyphens to
    # underscores, so the identifier `path` lands on PATH and `ld_preload` on
    # LD_PRELOAD -- and a caller eval'ing the output would have its command
    # resolution or process loading hijacked, with no metacharacter involved.
    # Refuse the names that steer the shell or the dynamic loader.
    local upper
    upper=$(printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_')
    case "$upper" in
        LD_*|DYLD_*|BASH_*) return 1 ;;
        PATH|IFS|ENV|CDPATH|SHELL|HOME|PWD|OLDPWD|PS1|PS2|PS3|PS4|SHLVL|GLIBC_TUNABLES|NODE_OPTIONS|PERL5OPT|PYTHONPATH|PYTHONSTARTUP)
            return 1 ;;
    esac
    return 0
}

json_value() {
    local b64
    b64=$(jq -r --arg k "$1" '.[$k] // "" | @base64') || return 1
    printf '%s' "$b64" | openssl base64 -d -A
}

encrypted_file_path() {
    local session="$1"
    echo "${SECRETS_DIR}/${session}.enc"
}

encrypted_read_store() {
    local session="$1"
    local file
    file=$(encrypted_file_path "$session")

    # No file yet is a legitimate empty store, not a failure.
    if [[ ! -f "$file" ]]; then
        echo "{}"
        return 0
    fi

    local password
    password=$(get_encryption_password)

    # A real decrypt failure (wrong password / corrupt file) MUST NOT masquerade
    # as an empty store: swallowing it into "{}" silently drops every secret on
    # the next write and produces an empty backup. Surface it as a nonzero
    # return so callers abort instead of losing data.
    local decrypted
    if decrypted=$(openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 -in "$file" -pass "pass:$password" 2>/dev/null); then
        printf '%s\n' "$decrypted"
        return 0
    fi
    echo "Error: failed to decrypt secrets store for session: $session (wrong password or corrupt file)" >&2
    return 1
}

encrypted_write_store() {
    local session="$1"
    local data="$2"
    local file
    file=$(encrypted_file_path "$session")

    mkdir -p "$SECRETS_DIR"
    chmod 700 "$SECRETS_DIR"

    local password
    password=$(get_encryption_password)

    # Transactional write: encrypt into a temp file in the SAME directory (same
    # filesystem, so the rename is atomic), then rename over the live store only
    # on success. This way a disk-full / interrupt / openssl failure / concurrent
    # writer never truncates or partially overwrites the existing ciphertext.
    local dir tmp
    dir=$(dirname "$file")
    tmp=$(mktemp "$dir/.XXXXXX") || {
        echo "Error: failed to create temp file for secrets store: $session" >&2
        return 1
    }
    chmod 600 "$tmp"

    if ! echo "$data" | openssl enc -aes-256-cbc -e -pbkdf2 -iter 100000 -out "$tmp" -pass "pass:$password"; then
        rm -f "$tmp"
        echo "Error: failed to encrypt secrets store for session: $session (existing store left intact)" >&2
        return 1
    fi

    # Atomic commit. The rename preserves the temp file's 0600 mode.
    if ! mv "$tmp" "$file"; then
        rm -f "$tmp"
        echo "Error: failed to commit secrets store for session: $session (existing store left intact)" >&2
        return 1
    fi
}

encrypted_lock_path() {
    printf '%s' "${SECRETS_DIR}/.lock.$1"
}

# Atomic per-session mutex around the encrypted store's read-modify-write.
# encrypted_write_store commits atomically, but store/delete READ then WRITE:
# without serialization two writers read the same base and the later commit
# clobbers the earlier writer's change (a lost update). A plain `echo $$ > lock`
# (as the session lock uses) is check-then-act and races; `set -o noclobber` is
# an atomic O_EXCL create, so exactly one concurrent writer wins. Portable to
# bash 3.2 + BSD (no flock). Blocks up to CS_SECRETS_LOCK_TIMEOUT seconds, then
# fails loud rather than racing.
#
# The lock is DELIBERATELY not auto-reaped when its holder PID looks dead. Any
# reaper that renames or removes the live lock path to reclaim it opens a window
# where a second process can acquire the same lock (a re-acquired lock cannot be
# told apart from the stale one without a second serializing lock, which just
# moves the hazard). Since the store/delete signal traps release on every
# catchable signal, a leaked lock means only SIGKILL / power-loss mid
# critical-section — rare — and we fail loud naming the file to remove rather
# than risk handing two writers the lock and silently losing a secret.
encrypted_lock_acquire() {
    local session="$1"
    local lock
    lock=$(encrypted_lock_path "$session")
    local timeout="${CS_SECRETS_LOCK_TIMEOUT:-10}"
    local max_attempts=$(( timeout * 10 ))
    local attempts=0

    mkdir -p "$SECRETS_DIR"
    chmod 700 "$SECRETS_DIR"

    # O_EXCL create carrying the holder PID; the redirect fails atomically when
    # the lock already exists, so only the winner writes.
    until ( set -o noclobber; echo "$$" > "$lock" ) 2>/dev/null; do
        if [ "$attempts" -ge "$max_attempts" ]; then
            local holder
            holder=$(cat "$lock" 2>/dev/null || echo "")
            echo "Error: timed out after ${timeout}s acquiring secrets lock for session '$session' (held by PID ${holder:-unknown}). If no such process is running, remove: $lock" >&2
            return 1
        fi
        sleep 0.1 2>/dev/null || sleep 1
        attempts=$(( attempts + 1 ))
    done
}

# Release the per-session mutex, but only if this process still owns it: a lock
# reaped as stale and re-acquired by another process must survive this holder's
# release and its signal trap.
encrypted_lock_release() {
    local session="$1"
    local lock
    lock=$(encrypted_lock_path "$session")
    [ -f "$lock" ] || return 0
    local holder
    holder=$(cat "$lock" 2>/dev/null || echo "")
    [ "$holder" = "$$" ] && rm -f "$lock"
    return 0
}

encrypted_store() {
    local session="$1"
    local name="$2"
    local value="$3"

    # Serialize the whole read-modify-write: the commit is atomic but the
    # read→modify→write sequence is not, so concurrent stores would lose updates
    # without this mutex. Install the cleanup traps BEFORE acquiring: the lock
    # file is created inside encrypted_lock_acquire, so a signal arriving between
    # its creation and the trap install would leak the lock permanently. Release
    # via the EXIT trap; encrypted_lock_release is a no-op until the lock holds
    # this PID, so pre-installing is safe on the failure path too. The signal
    # traps EXIT explicitly (firing the EXIT trap, then terminating) rather than
    # only releasing: bash does not auto-exit after a signal handler returns, so
    # a release-only handler would drop the lock and keep running lock-less
    # through the critical section, letting another writer interleave.
    trap 'encrypted_lock_release "$session"' EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    encrypted_lock_acquire "$session" \
        || error "Refusing to store: could not acquire secrets lock for session '$session'"

    # If the existing store can't be read, storing now would overwrite it with a
    # fresh single-key object, silently destroying every other secret. Abort.
    local store
    store=$(encrypted_read_store "$session") \
        || error "Refusing to store: existing secrets for session '$session' could not be read (wrong password or corrupt file)"

    local updated
    updated=$(echo "$store" | jq --arg name "$name" --arg value "$value" '.[$name] = $value')

    # Errexit does not cover this: callers reach store/delete through
    # `|| error`, which suppresses it for the whole call tree, so an unchecked
    # write would report success having written nothing.
    encrypted_write_store "$session" "$updated" \
        || error "Failed to store secret '$name' for session '$session'"

    encrypted_lock_release "$session"
    trap - EXIT INT TERM HUP
    echo "Stored secret: $name"
}

encrypted_get() {
    local session="$1"
    local name="$2"

    local store
    store=$(encrypted_read_store "$session") \
        || error "Cannot read secrets for session '$session' (wrong password or corrupt file)"

    local value
    value=$(echo "$store" | json_value "$name")

    if [[ -z "$value" ]]; then
        # Store read fine but the key is absent: a genuine not-found, distinct
        # from the read failure handled above.
        echo "Error: secret not found: $name" >&2
        return "$CS_NOT_FOUND"
    fi
    echo "$value"
}

encrypted_list() {
    local session="$1"

    local store
    store=$(encrypted_read_store "$session") \
        || error "Cannot list secrets for session '$session' (wrong password or corrupt file)"

    local keys
    keys=$(echo "$store" | json_keys) \
        || error "Failed to parse secrets store for session: $session"

    if [[ -z "$keys" ]]; then
        echo "No secrets stored for session: $session"
    else
        echo "Secrets for session: $session"
        echo "$keys" | while read -r name; do
            echo "  - $name"
        done
    fi
}

encrypted_delete() {
    local session="$1"
    local name="$2"

    # Same lost-update hazard as encrypted_store: serialize read-modify-write.
    # See encrypted_store for why traps are installed before acquiring and why
    # the signal traps exit rather than only release.
    trap 'encrypted_lock_release "$session"' EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    encrypted_lock_acquire "$session" \
        || error "Cannot delete secret: could not acquire secrets lock for session '$session'"

    local store
    store=$(encrypted_read_store "$session") \
        || error "Cannot delete secret: store for session '$session' could not be read (wrong password or corrupt file)"

    # Check if key exists
    if ! echo "$store" | jq -e --arg name "$name" 'has($name)' >/dev/null 2>&1; then
        error "Secret not found: $name"
    fi

    local updated
    updated=$(echo "$store" | jq --arg name "$name" 'del(.[$name])')

    # Checked for the same reason encrypted_store checks it.
    encrypted_write_store "$session" "$updated" \
        || error "Failed to delete secret '$name' for session '$session'"

    encrypted_lock_release "$session"
    trap - EXIT INT TERM HUP
    echo "Deleted secret: $name"
}

encrypted_purge() {
    local session="$1"
    local file
    file=$(encrypted_file_path "$session")

    # Hold the same per-session mutex store/delete use, across the whole purge:
    # otherwise a concurrent store that read the store under lock can rename its
    # update into place AFTER this removes the file, resurrecting purged secrets
    # (or the count/existence check races a concurrent commit). Traps installed
    # before acquire, and exiting on signal — see encrypted_store for why.
    trap 'encrypted_lock_release "$session"' EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    encrypted_lock_acquire "$session" \
        || error "Cannot purge secrets: could not acquire secrets lock for session '$session'"

    if [[ ! -f "$file" ]]; then
        encrypted_lock_release "$session"
        trap - EXIT INT TERM HUP
        echo "No secrets to purge for session: $session"
        return 0
    fi

    # Purge deletes the file regardless, so an unreadable store is tolerated
    # here (only the displayed count is approximate) — unlike the backup path,
    # dropping a corrupt file is the intended destructive outcome.
    local store
    store=$(encrypted_read_store "$session" 2>/dev/null) || store="{}"
    local count
    count=$(echo "$store" | jq 'keys | length' 2>/dev/null || echo "0")

    # The removal is the destructive action — a failure here must not report
    # success (the count above is only cosmetic and stays tolerant).
    rm -f "$file" || error "Failed to remove secrets file for session: $session"

    encrypted_lock_release "$session"
    trap - EXIT INT TERM HUP
    echo "Purged $count secret(s) for session: $session"
}

encrypted_export() {
    local session="$1"

    local store
    store=$(encrypted_read_store "$session") \
        || error "Cannot export secrets for session '$session' (wrong password or corrupt file)"

    # Render the lines here rather than inside jq: jq.exe emits CRLF, which
    # would ride into the eval'd output on every line but the last and leave
    # those variables holding a trailing CR. Same %q quoting keychain_export
    # uses, so both backends export identically.
    local name value var_name
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        value=$(echo "$store" | json_value "$name") \
            || error "Failed to format secrets for export for session: $session"
        valid_secret_name "$name" \
            || error "Refusing to export session '$session': stored secret name '$name' is not a valid identifier and would execute when this output is eval'd. Remove it with: cs -secrets delete '$name'"
        var_name=$(echo "$name" | tr '[:lower:]-' '[:upper:]_')
        printf 'export %s=%q\n' "$var_name" "$value"
    done <<< "$(echo "$store" | json_keys)"
}


# ============================================================================
# WINDOWS CREDENTIAL MANAGER BACKEND (msys / Git-Bash on Windows)
# ============================================================================
#
# Secrets are stored via the Windows Credential Manager. cs-secrets shells out
# to a fixed PowerShell helper (`-File`, never `-Command` string interpolation)
# that P/Invokes CredWrite/CredRead/CredDelete/CredEnumerate. The security
# contract: the secret and the session/name metadata NEVER touch the argv —
# session/name travel via the CS_WCM_SESSION/CS_WCM_NAME environment variables,
# and the secret travels base64-encoded on stdin (store) / stdout (get).
#
# The P/Invoke helper itself is Windows-only and cannot be exercised off
# Windows; the bash contract here (env-not-argv, base64 in/out, dispatch, exit
# codes) is covered by tests that substitute a fake powershell.exe, and the
# real CredMan behaviour is validated on the Windows CI lane.

# base64 encode/decode helpers. openssl is a hard dependency (encrypted backend)
# and its -A flag round-trips as a single line on both BSD and GNU userland,
# unlike base64(1) whose decode flag differs (-D on BSD, -d on GNU).
_wcm_b64_encode() { openssl base64 -A; }

# Strict base64 decode. `openssl base64 -d` (like most decoders) returns EXIT 0
# with EMPTY output for malformed input, so a corrupt/truncated helper response
# would silently become an empty secret. Validate the input is well-formed
# base64 (alphabet + up to two '=' pad chars, length a multiple of 4) before
# decoding, and fail nonzero on anything else. Empty input is the only case that
# decodes to empty, and it is accepted as-is.
_wcm_b64_decode() {
    local b64
    b64=$(cat)
    b64=$(printf '%s' "$b64" | tr -d '[:space:]')
    [[ -z "$b64" ]] && return 0
    local rem=$(( ${#b64} % 4 ))
    if ! printf '%s' "$b64" | grep -Eq '^[A-Za-z0-9+/]*={0,2}$' || [[ $rem -ne 0 ]]; then
        echo "Error: malformed base64 from Credential Manager helper (corrupt or truncated response)" >&2
        return 1
    fi
    printf '%s' "$b64" | openssl base64 -d -A
}

# Path to the embedded PowerShell helper, materialised once per process.
_WCM_HELPER_PATH=""
_wcm_helper_path() {
    if [[ -n "$_WCM_HELPER_PATH" && -f "$_WCM_HELPER_PATH" ]]; then
        printf '%s' "$_WCM_HELPER_PATH"
        return 0
    fi
    local tmp ps1
    tmp="$(mktemp)" || return 1
    ps1="${tmp}.ps1"
    mv "$tmp" "$ps1" 2>/dev/null || ps1="$tmp"
    cat > "$ps1" <<'WCM_PS1'
# ABOUTME: Windows Credential Manager helper for cs-secrets (P/Invoke CredMan).
# ABOUTME: Reads CS_WCM_SESSION/CS_WCM_NAME from env; verb on argv; base64 on stdin/stdout.
$ErrorActionPreference = 'Stop'

$verb = $args[0]
$session = $env:CS_WCM_SESSION
$name = $env:CS_WCM_NAME
$target = "cs:${session}:${name}"

$typeDef = @"
using System;
using System.Runtime.InteropServices;
using System.Collections.Generic;

public static class CsWcm
{
    private const uint CRED_TYPE_GENERIC = 1;
    private const uint CRED_PERSIST_LOCAL_MACHINE = 2;
    private const int ERROR_NOT_FOUND = 1168;
    public const int MAX_BLOB = 2560;

    [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
    private struct CREDENTIAL
    {
        public uint Flags;
        public uint Type;
        public string TargetName;
        public string Comment;
        public System.Runtime.InteropServices.ComTypes.FILETIME LastWritten;
        public uint CredentialBlobSize;
        public IntPtr CredentialBlob;
        public uint Persist;
        public uint AttributeCount;
        public IntPtr Attributes;
        public string TargetAlias;
        public string UserName;
    }

    [DllImport("advapi32.dll", EntryPoint = "CredWriteW", CharSet = CharSet.Unicode, SetLastError = true)]
    private static extern bool CredWriteW(ref CREDENTIAL credential, uint flags);

    [DllImport("advapi32.dll", EntryPoint = "CredReadW", CharSet = CharSet.Unicode, SetLastError = true)]
    private static extern bool CredReadW(string target, uint type, uint flags, out IntPtr credential);

    [DllImport("advapi32.dll", EntryPoint = "CredDeleteW", CharSet = CharSet.Unicode, SetLastError = true)]
    private static extern bool CredDeleteW(string target, uint type, uint flags);

    [DllImport("advapi32.dll", EntryPoint = "CredEnumerateW", CharSet = CharSet.Unicode, SetLastError = true)]
    private static extern bool CredEnumerateW(string filter, uint flags, out uint count, out IntPtr credentials);

    [DllImport("advapi32.dll")]
    private static extern void CredFree(IntPtr buffer);

    public static void Write(string target, byte[] blob)
    {
        IntPtr blobPtr = Marshal.AllocHGlobal(blob.Length);
        try
        {
            Marshal.Copy(blob, 0, blobPtr, blob.Length);
            CREDENTIAL cred = new CREDENTIAL();
            cred.Type = CRED_TYPE_GENERIC;
            cred.TargetName = target;
            cred.CredentialBlobSize = (uint)blob.Length;
            cred.CredentialBlob = blobPtr;
            cred.Persist = CRED_PERSIST_LOCAL_MACHINE;
            cred.UserName = target;
            if (!CredWriteW(ref cred, 0))
            {
                throw new System.ComponentModel.Win32Exception(Marshal.GetLastWin32Error());
            }
        }
        finally
        {
            Marshal.FreeHGlobal(blobPtr);
        }
    }

    // Returns null when the credential does not exist.
    public static byte[] Read(string target)
    {
        IntPtr credPtr;
        if (!CredReadW(target, CRED_TYPE_GENERIC, 0, out credPtr))
        {
            int err = Marshal.GetLastWin32Error();
            if (err == ERROR_NOT_FOUND) { return null; }
            throw new System.ComponentModel.Win32Exception(err);
        }
        try
        {
            CREDENTIAL cred = (CREDENTIAL)Marshal.PtrToStructure(credPtr, typeof(CREDENTIAL));
            byte[] blob = new byte[cred.CredentialBlobSize];
            if (cred.CredentialBlobSize > 0)
            {
                Marshal.Copy(cred.CredentialBlob, blob, 0, (int)cred.CredentialBlobSize);
            }
            return blob;
        }
        finally
        {
            CredFree(credPtr);
        }
    }

    // Returns false when the credential does not exist.
    public static bool Delete(string target)
    {
        if (!CredDeleteW(target, CRED_TYPE_GENERIC, 0))
        {
            int err = Marshal.GetLastWin32Error();
            if (err == ERROR_NOT_FOUND) { return false; }
            throw new System.ComponentModel.Win32Exception(err);
        }
        return true;
    }

    public static List<string> Enumerate(string filter)
    {
        uint count;
        IntPtr credsPtr;
        List<string> names = new List<string>();
        if (!CredEnumerateW(filter, 0, out count, out credsPtr))
        {
            int err = Marshal.GetLastWin32Error();
            if (err == ERROR_NOT_FOUND) { return names; }
            throw new System.ComponentModel.Win32Exception(err);
        }
        try
        {
            for (int i = 0; i < count; i++)
            {
                IntPtr credPtr = Marshal.ReadIntPtr(credsPtr, i * IntPtr.Size);
                CREDENTIAL cred = (CREDENTIAL)Marshal.PtrToStructure(credPtr, typeof(CREDENTIAL));
                names.Add(cred.TargetName);
            }
        }
        finally
        {
            CredFree(credsPtr);
        }
        return names;
    }
}
"@

Add-Type -TypeDefinition $typeDef -Language CSharp

switch ($verb)
{
    'store'
    {
        $b64 = [Console]::In.ReadToEnd()
        $blob = [Convert]::FromBase64String($b64.Trim())
        if ($blob.Length -gt [CsWcm]::MAX_BLOB) { exit 2 }
        [CsWcm]::Write($target, $blob)
        exit 0
    }
    'get'
    {
        $blob = [CsWcm]::Read($target)
        if ($blob -eq $null) { exit 3 }
        [Console]::Out.Write([Convert]::ToBase64String($blob))
        exit 0
    }
    'delete'
    {
        if ([CsWcm]::Delete($target)) { exit 0 } else { exit 3 }
    }
    'list'
    {
        $prefix = "cs:${session}:"
        foreach ($t in [CsWcm]::Enumerate("cs:${session}:*"))
        {
            if ($t.StartsWith($prefix)) { [Console]::Out.WriteLine($t.Substring($prefix.Length)) }
        }
        exit 0
    }
    default
    {
        [Console]::Error.WriteLine("cs-wcm: unknown verb: $verb")
        exit 64
    }
}
WCM_PS1
    _WCM_HELPER_PATH="$ps1"
    printf '%s' "$_WCM_HELPER_PATH"
}

# Invoke the PowerShell helper for one verb. Metadata is passed by the caller
# via CS_WCM_SESSION/CS_WCM_NAME in the environment (never argv); store reads
# base64 on stdin, get writes base64 on stdout.
_wcm_run() {
    local verb="$1"
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$(_wcm_helper_path)" "$verb"
}

wcm_store() {
    local session="$1"
    local name="$2"
    local value="$3"
    _wcm_helper_path >/dev/null || error "Failed to prepare Credential Manager helper"

    local rc=0
    printf '%s' "$value" | _wcm_b64_encode \
        | ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run store ) || rc=$?

    # Preserve the helper's exit code so callers can distinguish failure modes:
    # 2 = blob over CRED_MAX_CREDENTIAL_BLOB_SIZE. Diverges from keychain/
    # encrypted (which funnel everything through error()/exit 1) by design —
    # WCM is new and the size cap is a WCM-specific, actionable condition.
    if [[ $rc -eq 0 ]]; then
        echo "Stored secret: $name"
    elif [[ $rc -eq 2 ]]; then
        echo "Error: secret too large for Credential Manager (max 2560 bytes): $name" >&2
        return 2
    else
        echo "Error: failed to store secret in Credential Manager: $name" >&2
        return "$rc"
    fi
}

wcm_get() {
    local session="$1"
    local name="$2"
    _wcm_helper_path >/dev/null || error "Failed to prepare Credential Manager helper"

    # Preserve the helper's exit code: 3 = credential not found (empty stdout),
    # anything else = a real read/helper failure. Diverges from keychain/
    # encrypted (exit 1) by design so a missing key is distinguishable from a
    # backend failure.
    local b64 rc=0
    b64=$( ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run get ) ) || rc=$?
    if [[ $rc -eq 0 ]]; then
        printf '%s' "$b64" | _wcm_b64_decode || {
            echo "Error: corrupt Credential Manager response for: $name" >&2
            return 1
        }
    elif [[ $rc -eq 3 ]]; then
        echo "Error: secret not found: $name" >&2
        return 3
    else
        echo "Error: failed to read secret from Credential Manager: $name" >&2
        return "$rc"
    fi
}

# Print each stored credential name for the session, one per line. Returns 0
# with empty output ONLY for a genuinely empty store (the .ps1 list verb maps
# CredEnumerate's ERROR_NOT_FOUND to an empty list + exit 0); a real
# enumeration/helper failure propagates as a NONZERO return, which callers must
# NOT swallow into "no secrets".
_wcm_names() {
    local session="$1"
    _wcm_helper_path >/dev/null || return 1
    ( export CS_WCM_SESSION="$session"; _wcm_run list )
}

wcm_list() {
    local session="$1"
    local names rc=0
    names=$(_wcm_names "$session") || rc=$?

    if [[ $rc -ne 0 ]]; then
        echo "Error: failed to enumerate Credential Manager secrets for session: $session" >&2
        return "$rc"
    fi

    if [[ -z "$names" ]]; then
        echo "No secrets stored for session: $session"
    else
        echo "Secrets for session: $session"
        printf '%s\n' "$names" | while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            echo "  - $name"
        done
    fi
}

wcm_delete() {
    local session="$1"
    local name="$2"
    _wcm_helper_path >/dev/null || error "Failed to prepare Credential Manager helper"

    if ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run delete ); then
        echo "Deleted secret: $name"
    else
        error "Secret not found or could not be deleted: $name"
    fi
}

wcm_purge() {
    local session="$1"
    local names rc=0
    names=$(_wcm_names "$session") || rc=$?

    if [[ $rc -ne 0 ]]; then
        echo "Error: failed to enumerate Credential Manager secrets for session: $session" >&2
        return "$rc"
    fi

    if [[ -z "$names" ]]; then
        echo "No secrets to purge for session: $session"
        return 0
    fi

    local count=0 failed=0 name
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run delete ) >/dev/null 2>&1; then
            count=$((count + 1))
        else
            failed=$((failed + 1))
        fi
    done <<< "$names"

    # A partial purge is a failure, not a success with a smaller count — report
    # loudly so the caller never believes a session was fully cleared.
    if [[ $failed -gt 0 ]]; then
        echo "Error: purged $count secret(s), but $failed delete(s) failed for session: $session" >&2
        return 1
    fi

    echo "Purged $count secret(s) for session: $session"
}

wcm_export() {
    local session="$1"
    local names rc=0
    names=$(_wcm_names "$session") || rc=$?

    if [[ $rc -ne 0 ]]; then
        echo "Error: failed to enumerate Credential Manager secrets for session: $session" >&2
        return "$rc"
    fi
    [[ -z "$names" ]] && return 0

    # Buffer the export and only emit it if EVERY listed credential is read: a
    # per-item read/decode failure must abort with nonzero rather than emit a
    # partial export the caller would eval as the complete set.
    local name b64 value var_name out=""
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if b64=$( ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run get ) 2>/dev/null ); then
            value=$(printf '%s' "$b64" | _wcm_b64_decode) || {
                echo "Error: corrupt Credential Manager response for: $name" >&2
                return 1
            }
            valid_secret_name "$name" \
                || error "Refusing to export session '$session': stored secret name '$name' is not a valid identifier and would execute when this output is eval'd. Remove it with: cs -secrets delete '$name'"
            var_name=$(echo "$name" | tr '[:lower:]-' '[:upper:]_')
            out+=$(printf 'export %s=%q' "$var_name" "$value")$'\n'
        else
            echo "Error: failed to read Credential Manager secret: $name" >&2
            return 1
        fi
    done <<< "$names"

    printf '%s' "$out"
}

# ============================================================================
# AGE ENCRYPTION (Public-key based sync)
# ============================================================================

AGE_KEY_DIR="${SECRETS_DIR}"
AGE_KEY_FILE="${AGE_KEY_DIR}/age.key"
AGE_PUB_FILE="${AGE_KEY_DIR}/age.pub"
AGE_BIN=""  # Set by age_find_binary

# Find age binary (checks PATH and our install location)
age_find_binary() {
    # Override seam, mirroring CLAUDE_CODE_BIN / CS_TMUX_BIN: an explicit path
    # decides the answer outright, so pointing it at something non-executable
    # means "no age on this machine" without having to rebuild PATH.
    if [[ -n "${CS_AGE_BIN:-}" ]]; then
        [[ -x "${CS_AGE_BIN}" ]] || return 1
        AGE_BIN="${CS_AGE_BIN}"
        echo "$AGE_BIN"
        return 0
    fi

    # Check if already found
    if [[ -n "$AGE_BIN" && -x "$AGE_BIN" ]]; then
        echo "$AGE_BIN"
        return 0
    fi

    # Check PATH first
    if command -v age &>/dev/null; then
        AGE_BIN=$(command -v age)
        echo "$AGE_BIN"
        return 0
    fi

    # Check our install location
    if [[ -x "$HOME/.local/bin/age" ]]; then
        AGE_BIN="$HOME/.local/bin/age"
        echo "$AGE_BIN"
        return 0
    fi

    return 1
}

# Check if age is available (without downloading)
age_available() {
    age_find_binary &>/dev/null
}

# Download age binary if not found
# Pinned age release and the SHA-256 of each official tarball
# (github.com/FiloSottile/age/releases). Bump AGE_VERSION and these together.
AGE_VERSION="v1.3.1"
_age_expected_sha() {
    case "$1" in
        darwin-amd64) echo "2b233301ad21ab7b1eabd9ae1198a164005fa4928fcdd745d47c39f8593209d7" ;;
        darwin-arm64) echo "01120ea2cbf0463d4c6bd767f99f3271bbed1cdc8a9aa718a76ba1fe4f01998b" ;;
        linux-amd64)  echo "bdc69c09cbdd6cf8b1f333d372a1f58247b3a33146406333e30c0f26e8f51377" ;;
        linux-arm64)  echo "c6878a324421b69e3e20b00ba17c04bc5c6dab0030cfe55bf8f68fa8d9e9093a" ;;
        linux-arm)    echo "0af5d0dd1664d43dda955938280a668fdd298ad0df90058b409067dfdec74ba3" ;;
        *)            echo "" ;;
    esac
}

# Portable SHA-256 of a file: shasum on BSD/macOS, sha256sum on Linux.
_age_sha256() {
    if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    elif command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    else
        echo ""
    fi
}

age_ensure_binary() {
    # Already available?
    if age_find_binary &>/dev/null; then
        return 0
    fi

    echo "age is needed for secure secret sync but was not found." >&2
    echo "age ${AGE_VERSION} will be downloaded from github.com/FiloSottile/age, checksum-verified, and installed to ~/.local/bin/" >&2

    if [[ -t 0 ]]; then
        local response
        read -r -p "Download age? [Y/n] " response </dev/tty
        case "$response" in
            [nN]|[nN][oO])
                echo "Skipped. Install age manually: brew install age" >&2
                return 1
                ;;
        esac
    else
        echo "Non-interactive shell — skipping auto-download. Install age manually." >&2
        return 1
    fi

    # Detect platform
    local os arch url
    case "$(uname -s)" in
        Darwin) os="darwin" ;;
        Linux)  os="linux" ;;
        *)
            echo "Warning: Unsupported OS for age auto-download" >&2
            return 1
            ;;
    esac

    case "$(uname -m)" in
        x86_64|amd64) arch="amd64" ;;
        arm64|aarch64) arch="arm64" ;;
        armv7l) arch="arm" ;;
        *)
            echo "Warning: Unsupported architecture for age auto-download" >&2
            return 1
            ;;
    esac

    local platform="${os}-${arch}"
    local expected_sha
    expected_sha=$(_age_expected_sha "$platform")
    if [[ -z "$expected_sha" ]]; then
        echo "Warning: no pinned age checksum for $platform — refusing unverified download. Install age manually: brew install age" >&2
        return 1
    fi
    url="https://github.com/FiloSottile/age/releases/download/${AGE_VERSION}/age-${AGE_VERSION}-${platform}.tar.gz"

    # Create temp directory for download
    local tmpdir
    tmpdir=$(mktemp -d)
    local tarball="$tmpdir/age.tar.gz"

    # Download to disk, verify the pinned SHA-256, and only then extract. The
    # checksum comes from cs (out of band from the download origin), so a
    # tampered CDN/mirror can't slip in a different binary.
    if ! curl -fsSL --connect-timeout 5 --max-time 120 "$url" -o "$tarball" 2>/dev/null; then
        rm -rf "$tmpdir"
        echo "Warning: Failed to download age. Falling back to encrypted file sync." >&2
        return 1
    fi
    local actual_sha
    actual_sha=$(_age_sha256 "$tarball")
    if [[ -z "$actual_sha" ]]; then
        rm -rf "$tmpdir"
        echo "Warning: no sha256 tool (shasum/sha256sum) to verify age — refusing to install unverified. Install age manually: brew install age" >&2
        return 1
    fi
    if [[ "$actual_sha" != "$expected_sha" ]]; then
        rm -rf "$tmpdir"
        echo "Error: age download checksum mismatch for $platform (expected $expected_sha, got $actual_sha). Aborting install." >&2
        return 1
    fi

    # Verified: extract and install.
    if tar xz -C "$tmpdir" -f "$tarball" 2>/dev/null; then
        mkdir -p "$HOME/.local/bin"

        # Handle both tarball structures (age/ prefix or flat)
        if [[ -f "$tmpdir/age/age" ]]; then
            mv "$tmpdir/age/age" "$HOME/.local/bin/"
            mv "$tmpdir/age/age-keygen" "$HOME/.local/bin/"
        elif [[ -f "$tmpdir/age" ]]; then
            mv "$tmpdir/age" "$HOME/.local/bin/"
            mv "$tmpdir/age-keygen" "$HOME/.local/bin/"
        else
            rm -rf "$tmpdir"
            echo "Warning: Unexpected archive structure" >&2
            return 1
        fi

        chmod +x "$HOME/.local/bin/age" "$HOME/.local/bin/age-keygen"
        rm -rf "$tmpdir"

        AGE_BIN="$HOME/.local/bin/age"
        echo "Installed age to ~/.local/bin/" >&2
        return 0
    else
        rm -rf "$tmpdir"
        echo "Warning: Failed to download age. Falling back to encrypted file sync." >&2
        return 1
    fi
}

# Generate keypair if not exists
age_ensure_keypair() {
    # Need age binary first
    if ! age_ensure_binary; then
        return 1
    fi

    mkdir -p "$AGE_KEY_DIR"
    chmod 700 "$AGE_KEY_DIR"

    if [[ -f "$AGE_KEY_FILE" ]]; then
        # Key exists, ensure pubkey is extracted
        if [[ ! -f "$AGE_PUB_FILE" ]]; then
            grep "^# public key:" "$AGE_KEY_FILE" | sed 's/^# public key: //' > "$AGE_PUB_FILE"
        fi
        return 0
    fi

    echo "Generating age keypair..." >&2

    # Generate new keypair
    local keygen_bin
    keygen_bin="${AGE_BIN%age}age-keygen"
    if [[ ! -x "$keygen_bin" ]]; then
        keygen_bin="$HOME/.local/bin/age-keygen"
    fi

    "$keygen_bin" -o "$AGE_KEY_FILE" 2>/dev/null
    chmod 600 "$AGE_KEY_FILE"

    # Extract public key
    grep "^# public key:" "$AGE_KEY_FILE" | sed 's/^# public key: //' > "$AGE_PUB_FILE"

    echo "Created keypair at $AGE_KEY_FILE" >&2
    echo "Public key: $(cat "$AGE_PUB_FILE")" >&2
    return 0
}

# Get this machine's public key
age_get_pubkey() {
    if [[ ! -f "$AGE_PUB_FILE" ]]; then
        if ! age_ensure_keypair; then
            return 1
        fi
    fi
    cat "$AGE_PUB_FILE"
}

# Get machine identifier for public key naming
# Identifies this machine for per-machine sync filenames. USER is unset under
# Git Bash (it exports USERNAME); a bare ${USER} would abort under `set -u` and
# collapse the name to "secrets..enc", which every machine would then share.
# Windows hostname.exe emits CRLF, so strip CR before it reaches a filename.
age_get_machine_id() {
    local user host
    user="${USER:-${USERNAME:-}}"
    [ -n "$user" ] || user=$(id -un 2>/dev/null) || user=""
    host=$(hostname -s 2>/dev/null || hostname 2>/dev/null) || host=""
    host=${host//$'\r'/}
    printf '%s@%s' "${user:-unknown}" "${host:-unknown}"
}

# Get recipients directory for a session
age_recipients_dir() {
    local session="$1"
    local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
    echo "${sessions_root}/${session}/.cs/age-recipients"
}

# Encrypt secrets JSON to age format
age_encrypt_secrets() {
    local session="$1"
    local secrets_json="$2"
    local output="$3"

    local age_bin
    if ! age_bin=$(age_find_binary); then
        return 1
    fi

    local recipients_dir
    recipients_dir=$(age_recipients_dir "$session")

    if [[ ! -d "$recipients_dir" ]] || [[ -z "$(ls -A "$recipients_dir" 2>/dev/null)" ]]; then
        echo "No age recipients configured. Run: cs -secrets age add <pubkey-file>" >&2
        return 1
    fi

    # Build recipient arguments
    local recipient_args=()
    for pubfile in "$recipients_dir"/*.pub; do
        [[ -f "$pubfile" ]] || continue
        recipient_args+=(-r "$(cat "$pubfile")")
    done

    if [[ ${#recipient_args[@]} -eq 0 ]]; then
        echo "No valid recipients found" >&2
        return 1
    fi

    # Encrypt
    echo "$secrets_json" | "$age_bin" "${recipient_args[@]}" -o "$output"
}

# Decrypt secrets from age format
age_decrypt_secrets() {
    local input="$1"

    local age_bin
    if ! age_bin=$(age_find_binary); then
        return 1
    fi

    if [[ ! -f "$AGE_KEY_FILE" ]]; then
        echo "No age identity found at $AGE_KEY_FILE" >&2
        return 1
    fi

    "$age_bin" -d -i "$AGE_KEY_FILE" < "$input"
}

# ============================================================================
# BACKEND DISPATCH
# ============================================================================

backend_store() {
    case "$BACKEND" in
        keychain)   keychain_store "$@" ;;
        wcm)        wcm_store "$@" ;;
        encrypted)  encrypted_store "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

backend_get() {
    case "$BACKEND" in
        keychain)   keychain_get "$@" ;;
        wcm)        wcm_get "$@" ;;
        encrypted)  encrypted_get "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

backend_list() {
    case "$BACKEND" in
        keychain)   keychain_list "$@" ;;
        wcm)        wcm_list "$@" ;;
        encrypted)  encrypted_list "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

backend_delete() {
    case "$BACKEND" in
        keychain)   keychain_delete "$@" ;;
        wcm)        wcm_delete "$@" ;;
        encrypted)  encrypted_delete "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

backend_purge() {
    case "$BACKEND" in
        keychain)   keychain_purge "$@" ;;
        wcm)        wcm_purge "$@" ;;
        encrypted)  encrypted_purge "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

backend_export() {
    case "$BACKEND" in
        keychain)   keychain_export "$@" ;;
        wcm)        wcm_export "$@" ;;
        encrypted)  encrypted_export "$@" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
}

# ============================================================================
# SYNC FILE OPERATIONS
# ============================================================================

# Detect sync file format from file path
sync_file_format() {
    local file="$1"
    case "$file" in
        *.age) echo "age" ;;
        *.enc) echo "enc" ;;
        *) echo "unknown" ;;
    esac
}

# Decrypt a single sync file to JSON on stdout. Returns non-zero (without
# exiting) when the file cannot be decrypted with the material available on
# this machine (another machine's age key, a different password), so callers
# can skip files that are not theirs instead of aborting.
decrypt_sync_file() {
    local file="$1"
    local format
    format=$(sync_file_format "$file")

    case "$format" in
        age)
            age_available || return 1
            age_decrypt_secrets "$file" 2>/dev/null || return 1
            ;;
        enc)
            [[ -n "${CS_SECRETS_PASSWORD:-}" ]] || return 1
            openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 \
                -in "$file" -pass "pass:${CS_SECRETS_PASSWORD}" 2>/dev/null || return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# True when an existing sync file already decrypts to JSON identical to the
# given payload. Every openssl/age run emits fresh ciphertext (random salt /
# ephemeral keys), so byte-comparing the file is meaningless; compare the
# decrypted, canonicalised JSON so export can skip rewrites that change nothing.
sync_file_unchanged() {
    local file="$1"
    local new_json="$2"

    [[ -f "$file" ]] || return 1

    local existing
    existing=$(decrypt_sync_file "$file") || return 1

    local existing_canon new_canon
    existing_canon=$(echo "$existing" | jq -S -c . 2>/dev/null) || return 1
    new_canon=$(echo "$new_json" | jq -S -c . 2>/dev/null) || return 1

    [[ "$existing_canon" == "$new_canon" ]]
}

# Collect all secrets as JSON from current backend
collect_secrets_json() {
    local session="$1"
    local json="{}"

    # A backup must be all-or-nothing: if enumeration fails, or ANY listed
    # credential fails to read/decode, return nonzero and emit no JSON so the
    # caller aborts rather than writing a partial/empty backup. A genuinely
    # empty store (no creds / no file) returns 0 with "{}".
    case "$BACKEND" in
        keychain)
            local dump
            if ! dump=$(security dump-keychain 2>/dev/null); then
                echo "Error: failed to enumerate Keychain for session: $session" >&2
                return 1
            fi
            local secrets
            # A genuinely empty store (grep no-match) yields empty output and 0;
            # a real grep/sed failure returns nonzero and must abort the backup.
            secrets=$(keychain_extract_names "$dump" "$session") || {
                echo "Error: failed to enumerate Keychain for session: $session" >&2
                return 1
            }
            if [[ -n "$secrets" ]]; then
                while IFS= read -r name; do
                    [[ -z "$name" ]] && continue
                    local service value
                    service=$(keychain_service "$session" "$name")
                    if value=$(security find-generic-password -a "$(keychain_user)" -s "$service" -w 2>/dev/null); then
                        json=$(echo "$json" | jq --arg name "$name" --arg value "$value" '.[$name] = $value') || return 1
                    else
                        echo "Error: failed to read Keychain secret: $name" >&2
                        return 1
                    fi
                done <<< "$secrets"
            fi
            ;;
        wcm)
            local names name b64 value rc=0
            names=$(_wcm_names "$session") || rc=$?
            if [[ $rc -ne 0 ]]; then
                echo "Error: failed to enumerate Credential Manager secrets for session: $session" >&2
                return 1
            fi
            if [[ -n "$names" ]]; then
                while IFS= read -r name; do
                    [[ -z "$name" ]] && continue
                    if b64=$( ( export CS_WCM_SESSION="$session" CS_WCM_NAME="$name"; _wcm_run get ) 2>/dev/null ); then
                        value=$(printf '%s' "$b64" | _wcm_b64_decode) || {
                            echo "Error: corrupt Credential Manager response for: $name" >&2
                            return 1
                        }
                        json=$(echo "$json" | jq --arg name "$name" --arg value "$value" '.[$name] = $value') || return 1
                    else
                        echo "Error: failed to read Credential Manager secret: $name" >&2
                        return 1
                    fi
                done <<< "$names"
            fi
            ;;
        encrypted)
            json=$(encrypted_read_store "$session") || return 1
            ;;
        *)
            error "Unknown backend: $BACKEND"
            ;;
    esac

    echo "$json"
}

# Export secrets to sync file (for git sync)
# Prefers age encryption if available and recipients configured, else falls back to password-encrypted .enc
export_to_sync_file() {
    local session="$1"
    local output="${2:-}"

    # Serialize the export against the encrypted store's mutations
    # (store/delete/purge) on this session. Export is a read (collect) → encrypt
    # → rename transaction; without the mutex a slow older export can rename a
    # stale snapshot over a newer sync file, silently losing a secret a
    # concurrent store committed (atomic rename prevents torn files, not a
    # stale-writer overwrite). ONLY the encrypted backend takes this lock: a
    # keychain/WCM store is atomic per credential (no read-modify-write to lose),
    # and coupling those backends' export to the encrypted backend's
    # ~/.cs-secrets would be a surprising new dependency (fails if HOME is
    # read-only or that path is a file). Unlike store/delete (single success
    # exit), export has several early returns, so the EXIT trap releases via a
    # GLOBAL — a function-local would be out of scope when the trap fires at
    # process exit (export is the terminal command) and trip set -u. Release is
    # idempotent. Signal traps exit — see encrypted_store.
    if [[ "${BACKEND:-}" == "encrypted" ]]; then
        _CS_EXPORT_LOCK_SESSION="$session"
        trap 'encrypted_lock_release "$_CS_EXPORT_LOCK_SESSION"' EXIT
        trap 'exit 130' INT
        trap 'exit 143' TERM
        trap 'exit 129' HUP
        encrypted_lock_acquire "$session" \
            || error "Aborting export for session '$session': could not acquire secrets lock"
    fi

    # Abort before writing anything if the backend can't hand back the complete
    # secret set — a partial/empty sync file would silently lose secrets on the
    # next restore.
    local secrets_json
    secrets_json=$(collect_secrets_json "$session") \
        || error "Aborting export for session '$session': backend ($BACKEND) could not read all secrets; refusing to write a partial backup"

    # Check if there are any secrets
    local count
    count=$(echo "$secrets_json" | jq 'keys | length')
    if [[ "$count" -eq 0 ]]; then
        echo "No secrets to export for session: $session"
        return 0
    fi

    local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
    local meta_dir="${sessions_root}/${session}/.cs"
    mkdir -p "$meta_dir"

    # Per-machine sync file name. Machines sharing a session over git each write
    # their own file, so concurrent exports never collide into an unmergeable
    # binary conflict that silently drops one side's secrets. Reuses the
    # hostname-derived id already used to name age recipients.
    local machine_id
    machine_id=$(age_get_machine_id)

    # Determine encryption method
    local use_age=false
    local recipients_dir
    recipients_dir=$(age_recipients_dir "$session")

    # Auto-setup age if available but not yet configured for this session
    if age_available; then
        if [[ ! -d "$recipients_dir" ]] || [[ -z "$(ls -A "$recipients_dir" 2>/dev/null)" ]]; then
            # No recipients yet - auto-add self if keypair exists or can be created
            if age_ensure_keypair 2>/dev/null; then
                mkdir -p "$recipients_dir"
                local pubkey
                pubkey=$(age_get_pubkey)
                echo "$pubkey" > "$recipients_dir/${machine_id}.pub"
                echo "Auto-configured age encryption for session (added ${machine_id})"
            fi
        fi
    fi

    if age_available && [[ -d "$recipients_dir" ]] && [[ -n "$(ls -A "$recipients_dir" 2>/dev/null)" ]]; then
        use_age=true
    fi

    if [[ "$use_age" == "true" ]]; then
        # Use age encryption
        local age_output="${output:-${meta_dir}/secrets.${machine_id}.age}"

        if sync_file_unchanged "$age_output" "$secrets_json"; then
            echo "No secret changes to export for session: $session ($(basename "$age_output") is up to date)"
            return 0
        fi

        # Atomic write: encrypt into a temp file in the same dir, then rename
        # over the live sync file only on success. Writing straight to
        # "$age_output" would truncate the previous good backup before the new
        # ciphertext is confirmed, losing it on a failed/interrupted encrypt.
        local age_dir age_tmp
        age_dir=$(dirname "$age_output")
        age_tmp=$(mktemp "$age_dir/.secrets.XXXXXX") \
            || error "Failed to create temp file for sync export in: $age_dir"
        if age_encrypt_secrets "$session" "$secrets_json" "$age_tmp"; then
            chmod 600 "$age_tmp"
            if ! mv "$age_tmp" "$age_output"; then
                rm -f "$age_tmp"
                error "Failed to commit sync export for session '$session' (existing sync file left intact)"
            fi
            echo "Exported $count secret(s) to: $age_output (age encrypted)"

            # Drop this machine's stale password file once it has an age file.
            local old_enc="${meta_dir}/secrets.${machine_id}.enc"
            if [[ -f "$old_enc" ]]; then
                rm -f "$old_enc"
                echo "Removed stale $(basename "$old_enc") (migrated to age)"
            fi
        else
            rm -f "$age_tmp"
            echo "Age encryption failed, falling back to password encryption" >&2
            use_age=false
        fi
    fi

    if [[ "$use_age" == "false" ]]; then
        # Fall back to password-encrypted .enc
        if [[ -z "${CS_SECRETS_PASSWORD:-}" ]]; then
            error "No age recipients configured and CS_SECRETS_PASSWORD not set.
Either:
  1. Set up age encryption: cs -secrets age init && cs -secrets age add ~/.cs-secrets/age.pub
  2. Or set CS_SECRETS_PASSWORD for legacy password-based sync"
        fi

        local enc_output="${output:-${meta_dir}/secrets.${machine_id}.enc}"

        if sync_file_unchanged "$enc_output" "$secrets_json"; then
            echo "No secret changes to export for session: $session ($(basename "$enc_output") is up to date)"
            return 0
        fi

        # Atomic write: encrypt into a temp file in the same dir, then rename
        # over the live sync file only on success. A direct -out "$enc_output"
        # opens (truncates) the previous good backup before openssl finishes, so
        # a failed/interrupted encrypt would leave it destroyed.
        local enc_dir enc_tmp
        enc_dir=$(dirname "$enc_output")
        enc_tmp=$(mktemp "$enc_dir/.secrets.XXXXXX") \
            || error "Failed to create temp file for sync export in: $enc_dir"
        if ! echo "$secrets_json" | openssl enc -aes-256-cbc -e -pbkdf2 -iter 100000 \
            -out "$enc_tmp" -pass "pass:$CS_SECRETS_PASSWORD"; then
            rm -f "$enc_tmp"
            error "Failed to encrypt sync export for session '$session' (existing sync file left intact)"
        fi
        chmod 600 "$enc_tmp"
        if ! mv "$enc_tmp" "$enc_output"; then
            rm -f "$enc_tmp"
            error "Failed to commit sync export for session '$session' (existing sync file left intact)"
        fi

        echo "Exported $count secret(s) to: $enc_output (password encrypted)"
    fi
}

# Import secrets from sync file(s)
# An explicit path imports just that file. Otherwise every per-machine sync
# file is merged, plus the legacy unsuffixed files (one-shot migration for
# sessions created before per-machine naming). Files that cannot be decrypted
# on this machine are skipped, not fatal.
import_from_sync_file() {
    local session="$1"
    local input="${2:-}"
    local mode="${3:-merge}"  # merge (default) or replace

    local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
    local meta_dir="${sessions_root}/${session}/.cs"

    # Collect candidate sync files.
    local files=()
    if [[ -n "$input" ]]; then
        if [[ ! -f "$input" ]]; then
            echo "No sync file found: $input"
            return 0
        fi
        files=("$input")
    else
        local candidate
        for candidate in \
            "$meta_dir"/secrets.*.age \
            "$meta_dir"/secrets.*.enc \
            "$meta_dir"/secrets.age \
            "$meta_dir"/secrets.enc; do
            [[ -f "$candidate" ]] && files+=("$candidate")
        done
        if [[ ${#files[@]} -eq 0 ]]; then
            echo "No sync file found in: $meta_dir"
            return 0
        fi
    fi

    # Decrypt and union every readable file. Earlier files win key collisions,
    # so per-machine files take precedence over the legacy shared files.
    local merged="{}"
    local sources=0
    local unreadable=0
    local f
    for f in "${files[@]}"; do
        local json
        if ! json=$(decrypt_sync_file "$f"); then
            unreadable=$((unreadable + 1))
            continue
        fi
        if ! echo "$json" | jq empty 2>/dev/null; then
            unreadable=$((unreadable + 1))
            continue
        fi
        merged=$(jq -n --argjson new "$json" --argjson acc "$merged" '$new * $acc')
        sources=$((sources + 1))
    done

    if [[ $sources -eq 0 ]]; then
        # Preserve the explicit-path diagnostics from the single-file era.
        if [[ -n "$input" ]]; then
            local format
            format=$(sync_file_format "$input")
            case "$format" in
                age)
                    age_available || error "age binary not found. Run: cs -secrets age init"
                    error "Failed to decrypt age file. Your key may not be in the recipients list."
                    ;;
                enc)
                    [[ -n "${CS_SECRETS_PASSWORD:-}" ]] || \
                        error "CS_SECRETS_PASSWORD required to decrypt .enc file. Set same password used during export."
                    error "Failed to decrypt sync file. Check CS_SECRETS_PASSWORD."
                    ;;
                *)
                    error "Unknown sync file format: $input"
                    ;;
            esac
        fi
        echo "No decryptable sync files found in: $meta_dir"
        if [[ $unreadable -gt 0 ]]; then
            echo "Skipped $unreadable undecryptable file(s) (need this machine's age key or CS_SECRETS_PASSWORD)."
        fi
        return 0
    fi

    # Import the merged secrets into the local backend.
    local imported=0
    local skipped=0
    local key
    while IFS= read -r key; do
        [[ -z "$key" ]] && continue
        local value probe_rc
        valid_secret_name "$key" \
            || error "Aborting import for session '$session': sync file carries an invalid secret name '$key'. A name must start with a letter or underscore and contain only letters, digits, underscore and hyphen; a name with shell metacharacters would execute when 'cs -secrets export' is eval'd."
        value=$(echo "$merged" | json_value "$key")

        # Decide whether to store. In replace mode we always overwrite. In merge
        # mode we store only when the secret is genuinely absent: probe the
        # backend and distinguish CS_NOT_FOUND (safe to store) from a real read
        # failure (must abort, or we would overwrite a secret we merely failed to
        # read). The subshell isolates error()'s exit from this loop.
        local should_store=0
        if [[ "$mode" == "replace" ]]; then
            should_store=1
        elif (backend_get "$session" "$key" >/dev/null 2>&1); then
            : # exists and readable — skip to preserve the local secret
        else
            probe_rc=$?
            if [[ $probe_rc -eq "$CS_NOT_FOUND" ]]; then
                should_store=1
            else
                error "Aborting import for session '$session': backend ($BACKEND) failed to read existing secret '$key' (exit $probe_rc); refusing to overwrite"
            fi
        fi

        if [[ $should_store -eq 1 ]]; then
            backend_store "$session" "$key" "$value" >/dev/null \
                || error "Failed to import secret '$key' into backend ($BACKEND)"
            imported=$((imported + 1))
        else
            skipped=$((skipped + 1))
        fi
    done <<< "$(echo "$merged" | json_keys)"

    echo "Imported $imported secret(s) from $sources sync file(s)."
    if [[ $skipped -gt 0 ]]; then
        echo "Skipped $skipped existing secret(s) (use --replace to overwrite)."
    fi
    if [[ $unreadable -gt 0 ]]; then
        echo "Skipped $unreadable undecryptable file(s) (need this machine's age key or CS_SECRETS_PASSWORD)."
    fi
}

# ============================================================================
# MIGRATE COMMAND
# ============================================================================

# Sensitive substrings that mark a key name as holding a secret value.
SENSITIVE_PATTERNS=("key" "secret" "password" "token" "credential" "auth" "apikey" "api_key")

is_sensitive_key() {
    local key="$1"
    local key_lower
    key_lower=$(echo "$key" | tr '[:upper:]' '[:lower:]')

    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if [[ "$key_lower" == *"$pattern"* ]]; then
            return 0
        fi
    done
    return 1
}

migrate_secrets() {
    local session="$1"
    local do_redact="$2"
    local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
    local session_dir="$sessions_root/$session"
    local artifacts_dir="$session_dir/.cs/artifacts"

    if [[ ! -d "$artifacts_dir" ]]; then
        echo "No artifacts directory found for session: $session"
        echo "Path checked: $artifacts_dir"
        return 0
    fi

    local migrated=0
    local files_updated=0

    echo "Scanning artifacts for plaintext secrets..."
    echo ""

    # Process each file in artifacts (excluding MANIFEST.json)
    while IFS= read -r -d '' file; do
        local filename
        filename=$(basename "$file")
        [[ "$filename" == "MANIFEST.json" ]] && continue

        local content
        content=$(cat "$file")
        local new_content="$content"
        local file_had_secrets=0

        # Process each line looking for KEY=value or KEY: value patterns
        while IFS= read -r line; do
            # Skip comments and empty lines
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// /}" ]] && continue

            local key=""
            local value=""

            # Pattern: KEY=value or KEY="value" or KEY='value'
            if [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=[[:space:]]*[\"\']?([^\"\']+)[\"\']?[[:space:]]*$ ]]; then
                key="${BASH_REMATCH[1]}"
                value="${BASH_REMATCH[2]}"
            # Pattern: KEY: value
            elif [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*:[[:space:]]+(.+)[[:space:]]*$ ]]; then
                key="${BASH_REMATCH[1]}"
                value="${BASH_REMATCH[2]}"
            fi

            [[ -z "$key" ]] && continue
            [[ -z "$value" ]] && continue

            # Skip if already redacted
            [[ "$value" == *"[REDACTED"* ]] && continue

            # Check if this looks like a sensitive key
            if is_sensitive_key "$key"; then
                # Store the secret
                backend_store "$session" "$key" "$value" >/dev/null \
                    || error "Failed to store migrated secret: $key"
                echo "  Migrated: $key (from $filename)"
                migrated=$((migrated + 1))
                file_had_secrets=1

                # Prepare redacted version if requested
                if [[ "$do_redact" -eq 1 ]]; then
                    local redacted_value="[REDACTED: stored in keychain as $key]"
                    # Escape special characters for sed
                    local escaped_value
                    escaped_value=$(printf '%s\n' "$value" | sed 's/[[\.*^$()+?{|]/\\&/g')
                    local escaped_redacted
                    escaped_redacted=$(printf '%s\n' "$redacted_value" | sed 's/[[\.*^$()+?{|]/\\&/g')
                    new_content=$(echo "$new_content" | sed "s|$escaped_value|$escaped_redacted|g")
                fi
            fi
        done <<< "$content"

        # Write redacted content back if we made changes
        if [[ "$do_redact" -eq 1 && "$file_had_secrets" -eq 1 ]]; then
            echo "$new_content" > "$file"
            files_updated=$((files_updated + 1))
        fi

    done < <(find "$artifacts_dir" -type f -print0)

    echo ""
    if [[ $migrated -eq 0 ]]; then
        echo "No plaintext secrets found to migrate."
    else
        echo "Migrated $migrated secret(s) to secure storage."
        if [[ "$do_redact" -eq 1 ]]; then
            echo "Updated $files_updated file(s) with redacted values."
        else
            echo ""
            echo "Tip: Run with --redact to replace plaintext values with redaction markers."
        fi
    fi
}

# Migrate secrets from one backend to another
migrate_backend() {
    local session="$1"
    local target_backend="$2"
    local delete_source="${3:-false}"
    local source_backend="${4:-$BACKEND}"

    # Validate target backend. The Windows backend is named `wcm` consistently
    # across validation, dispatch, and detect_backend.
    case "$target_backend" in
        keychain|wcm|encrypted) ;;
        *) error "Invalid target backend: $target_backend. Must be one of: keychain, wcm, encrypted" ;;
    esac

    # Validate source backend if specified
    if [[ -n "$4" ]]; then
        case "$source_backend" in
            keychain|wcm|encrypted) ;;
            *) error "Invalid source backend: $source_backend. Must be one of: keychain, wcm, encrypted" ;;
        esac
    fi

    if [[ "$target_backend" == "$source_backend" ]]; then
        error "Target backend '$target_backend' is the same as source backend"
    fi

    echo "Migrating secrets from '$source_backend' to '$target_backend'..."
    echo ""

    # Temporarily set BACKEND to source for collection
    local original_backend="$BACKEND"
    BACKEND="$source_backend"

    # Collect secrets from source backend as JSON. Abort the migration if the
    # source can't be fully read — migrating a partial set (then optionally
    # purging the source) would lose secrets.
    local secrets_json
    secrets_json=$(collect_secrets_json "$session") || {
        BACKEND="$original_backend"
        error "Aborting migration: source backend '$source_backend' could not read all secrets for session '$session'"
    }

    # Restore original backend
    BACKEND="$original_backend"

    local count
    count=$(echo "$secrets_json" | jq 'keys | length') \
        || error "Failed to parse collected secrets for session: $session"

    if [[ "$count" -eq 0 ]]; then
        echo "No secrets to migrate for session: $session"
        return 0
    fi

    echo "Found $count secret(s) to migrate"

    # Store each secret in target backend
    local migrated=0
    BACKEND="$target_backend"

    while IFS= read -r key; do
        [[ -z "$key" ]] && continue
        local value
        value=$(echo "$secrets_json" | json_value "$key")

        if backend_store "$session" "$key" "$value" >/dev/null 2>&1; then
            echo "  Migrated: $key"
            migrated=$((migrated + 1))
        else
            echo "  Failed: $key" >&2
        fi
    done <<< "$(echo "$secrets_json" | json_keys)"

    echo ""
    echo "Migrated $migrated of $count secret(s) to $target_backend"

    # Optionally delete from source — only when the migration was complete.
    if [[ "$delete_source" == "true" && $migrated -eq $count ]]; then
        echo ""
        echo "Removing migrated secrets from source backend ($source_backend)..."
        BACKEND="$source_backend"
        # Delete ONLY the keys we migrated, not a blanket purge: a secret stored
        # to the source AFTER our (unlocked) collect snapshot is not in the
        # migrated set, and a blanket purge would delete it without ever
        # migrating it (lost). Per-key delete leaves such a concurrently-added
        # secret intact.
        #
        # The subshell isolates backend_delete's error()/exit: several backends
        # exit nonzero on a not-found key, and a bare `|| true` cannot catch a
        # function's `exit` (it terminates the whole script) — only a subshell
        # boundary can. A key already gone (concurrent delete) is fine: the
        # migration's copy already fully succeeded, so a vanished source key just
        # means the source is already in the desired state. A genuine delete
        # failure leaves the secret in BOTH source and target (duplication, not
        # loss), so warn but do not abort a migration that otherwise succeeded.
        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            if ! ( backend_delete "$session" "$key" ) >/dev/null 2>&1; then
                echo "  Note: could not remove '$key' from source ($source_backend) — already gone or a backend error; it may remain there" >&2
            fi
        done <<< "$(echo "$secrets_json" | json_keys)"
    elif [[ "$delete_source" == "true" ]]; then
        echo ""
        echo "Skipping source purge - not all secrets migrated successfully" >&2
    fi

    # Restore original backend
    BACKEND="$original_backend"

    # A partial migration must fail loudly so no caller (and no --delete-source
    # decision) treats a lossy migration as success.
    if [[ $migrated -ne $count ]]; then
        error "Migration incomplete: only $migrated of $count secret(s) reached $target_backend"
    fi
}

# ============================================================================
# MAIN
# ============================================================================

# Parse arguments
SESSION_NAME="${CS_SECRETS_SESSION:-${CLAUDE_SESSION_NAME:-}}"
COMMAND=""
AGE_SUBCOMMAND=""
SECRET_NAME=""
SECRET_VALUE=""
DO_REDACT=0
IMPORT_MODE="merge"
DELETE_SOURCE="false"
FROM_BACKEND=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--session)
            SESSION_NAME="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        age)
            COMMAND="age"
            AGE_SUBCOMMAND="${2:-}"
            # Capture argument after subcommand (e.g., pubkey file or recipient name)
            SECRET_NAME="${3:-}"
            shift
            [[ -n "$AGE_SUBCOMMAND" ]] && shift
            [[ -n "$SECRET_NAME" ]] && shift
            ;;
        set|store|get|list|ls|delete|rm|purge|export|export-file|import-file|migrate|migrate-backend|backend)
            COMMAND="$1"
            shift
            ;;
        --redact)
            DO_REDACT=1
            shift
            ;;
        --replace)
            IMPORT_MODE="replace"
            shift
            ;;
        --delete-source)
            DELETE_SOURCE="true"
            shift
            ;;
        --from)
            FROM_BACKEND="$2"
            shift 2
            ;;
        *)
            if [[ -z "$SECRET_NAME" ]]; then
                SECRET_NAME="$1"
            elif [[ -z "$SECRET_VALUE" ]]; then
                SECRET_VALUE="$1"
            fi
            shift
            ;;
    esac
done

# Handle backend command specially
if [[ "$COMMAND" == "backend" ]]; then
    echo "Storage backend: $BACKEND"
    case "$BACKEND" in
        keychain)   echo "Using macOS Keychain" ;;
        wcm)        echo "Using Windows Credential Manager (PowerShell)" ;;
        encrypted)  echo "Using OpenSSL-encrypted file (~/.cs-secrets/)" ;;
        *)          error "Unknown backend: $BACKEND" ;;
    esac
    exit 0
fi

# Handle age commands (some don't require session)
if [[ "$COMMAND" == "age" ]]; then
    case "$AGE_SUBCOMMAND" in
        init)
            # Initialize age - no session needed
            if age_ensure_keypair; then
                echo "Age encryption ready."
                echo "Public key: $(age_get_pubkey)"
            else
                exit 1
            fi
            exit 0
            ;;
        pubkey)
            # Get public key - no session needed
            if pubkey=$(age_get_pubkey); then
                echo "$pubkey"
            else
                exit 1
            fi
            exit 0
            ;;
        add)
            # Add recipient - requires session
            require_session
            [[ -z "$SECRET_NAME" ]] && error "Usage: age add <pubkey-file-or-key>"

            _age_recipients_dir=$(age_recipients_dir "$SESSION_NAME")
            mkdir -p "$_age_recipients_dir"

            if [[ -f "$SECRET_NAME" ]]; then
                # It's a file
                _age_pubkey=$(cat "$SECRET_NAME")
                _age_machine_id=$(basename "$SECRET_NAME" .pub)
            elif [[ "$SECRET_NAME" == age1* ]]; then
                # It's a raw public key
                _age_pubkey="$SECRET_NAME"
                _age_machine_id="recipient-$(date +%s)"
            else
                error "Invalid public key. Must be a file or age1... public key"
            fi

            # Validate it looks like an age public key
            if [[ ! "$_age_pubkey" == age1* ]]; then
                error "Invalid age public key format"
            fi

            echo "$_age_pubkey" > "$_age_recipients_dir/${_age_machine_id}.pub"
            echo "Added recipient: $_age_machine_id"
            echo "Public key: $_age_pubkey"
            exit 0
            ;;
        list|ls)
            # List recipients - requires session
            require_session

            _age_recipients_dir=$(age_recipients_dir "$SESSION_NAME")

            if [[ ! -d "$_age_recipients_dir" ]] || [[ -z "$(ls -A "$_age_recipients_dir" 2>/dev/null)" ]]; then
                echo "No recipients configured for session: $SESSION_NAME"
                echo ""
                echo "Add recipients with: cs -secrets age add <pubkey-file>"
                exit 0
            fi

            echo "Recipients for session: $SESSION_NAME"
            for _age_pubfile in "$_age_recipients_dir"/*.pub; do
                [[ -f "$_age_pubfile" ]] || continue
                _age_name=$(basename "$_age_pubfile" .pub)
                _age_key=$(cat "$_age_pubfile")
                echo "  - $_age_name: ${_age_key:0:20}..."
            done
            exit 0
            ;;
        remove|rm)
            # Remove recipient - requires session
            require_session
            [[ -z "$SECRET_NAME" ]] && error "Usage: age remove <recipient-name>"

            _age_recipients_dir=$(age_recipients_dir "$SESSION_NAME")
            _age_pubfile="$_age_recipients_dir/${SECRET_NAME}.pub"

            if [[ ! -f "$_age_pubfile" ]]; then
                error "Recipient not found: $SECRET_NAME"
            fi

            rm "$_age_pubfile"
            echo "Removed recipient: $SECRET_NAME"
            echo ""
            echo "Note: Existing secrets.age files can still be decrypted by this recipient."
            echo "Re-export secrets to re-encrypt without this recipient."
            exit 0
            ;;
        "")
            error "Usage: age <init|pubkey|add|list|remove>"
            ;;
        *)
            error "Unknown age subcommand: $AGE_SUBCOMMAND"
            ;;
    esac
fi

# Validate session
if [[ -n "$COMMAND" ]]; then
    require_session
fi

# Execute command
case "$COMMAND" in
    store|set)
        [[ -z "$SECRET_NAME" ]] && error "Secret name required"
        if [[ -n "$SECRET_VALUE" ]]; then
            # A value on argv is visible via `ps` and is captured verbatim by
            # the bash-logger hook into the on-disk session.log. Warn and steer
            # callers to stdin, but still honour it for interactive use.
            echo "Warning: passing the value on the command line exposes it via ps and session.log." >&2
            echo "         Prefer stdin: cs -secrets set $SECRET_NAME < valuefile" >&2
        elif [[ -t 0 ]]; then
            printf "Enter value for %s: " "$SECRET_NAME"
            IFS= read -r SECRET_VALUE || true
        else
            # Non-interactive: take the secret from stdin so it never appears on
            # argv or in the bash-logger command capture.
            SECRET_VALUE="$(cat)"
        fi
        [[ -z "$SECRET_VALUE" ]] && error "Secret value cannot be empty"
        valid_secret_name "$SECRET_NAME" \
            || error "Refusing to store: invalid secret name '$SECRET_NAME'. A name must start with a letter or underscore and contain only letters, digits, underscore and hyphen, because it becomes a shell variable name in 'cs -secrets export'."
        backend_store "$SESSION_NAME" "$SECRET_NAME" "$SECRET_VALUE"
        ;;
    get)
        [[ -z "$SECRET_NAME" ]] && error "Secret name required"
        backend_get "$SESSION_NAME" "$SECRET_NAME"
        ;;
    list|ls)
        backend_list "$SESSION_NAME"
        ;;
    delete|rm)
        [[ -z "$SECRET_NAME" ]] && error "Secret name required"
        backend_delete "$SESSION_NAME" "$SECRET_NAME"
        ;;
    purge)
        backend_purge "$SESSION_NAME"
        ;;
    export)
        backend_export "$SESSION_NAME"
        ;;
    export-file)
        # SECRET_NAME holds optional file path argument
        export_to_sync_file "$SESSION_NAME" "$SECRET_NAME"
        ;;
    import-file)
        # SECRET_NAME holds optional file path argument
        import_from_sync_file "$SESSION_NAME" "$SECRET_NAME" "$IMPORT_MODE"
        ;;
    migrate)
        migrate_secrets "$SESSION_NAME" "$DO_REDACT"
        ;;
    migrate-backend)
        [[ -z "$SECRET_NAME" ]] && error "Target backend required. Usage: migrate-backend <backend> [--from <backend>] [--delete-source]"
        migrate_backend "$SESSION_NAME" "$SECRET_NAME" "$DELETE_SOURCE" "$FROM_BACKEND"
        ;;
    "")
        usage
        ;;
    *)
        error "Unknown command: $COMMAND"
        ;;
esac
