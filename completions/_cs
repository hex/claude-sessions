#compdef cs
# ABOUTME: Zsh completion script for cs (Claude Code session manager)
# ABOUTME: Provides tab-completion for session names, commands, and subcommands

_cs() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    # Helper: get session names. cs owns the definition of a session, including
    # which symlinks and marker directories count; asking it keeps this script
    # from drifting out of step with `cs -list`.
    _cs_sessions() {
        local -a sessions session_descs
        local s
        sessions=(${(f)"$(cs -complete sessions 2>/dev/null)"})
        sessions=(${sessions:#})
        (( ${#sessions} )) || return 1
        # Use _describe so zsh shows a menu even when one name is an
        # exact prefix of another (e.g., "comfy" and "comfy-nodes")
        for s in "${sessions[@]}"; do
            session_descs+=("${s}:session")
        done
        _describe 'session' session_descs
    }

    # Secrets subcommands with descriptions
    local -a secrets_cmds
    secrets_cmds=(
        'set:Store a secret'
        'store:Store a secret (alias)'
        'get:Retrieve a secret value'
        'list:List all secrets'
        'ls:List all secrets (alias)'
        'delete:Delete a secret'
        'rm:Delete a secret (alias)'
        'purge:Delete ALL secrets'
        'export:Export as environment variables'
        'export-file:Export to encrypted file'
        'import-file:Import from encrypted file'
        'migrate:Migrate plaintext secrets'
        'migrate-backend:Migrate secrets to another backend'
        'backend:Show storage backend'
        'age:Manage age public-key encryption for sync'
    )

    # Checkpoint subcommands with descriptions
    local -a checkpoint_cmds
    checkpoint_cmds=(
        'list:List checkpoints for current session'
        'show:Print a specific checkpoint'
    )

    # Queue subcommands with descriptions
    local -a queue_cmds
    queue_cmds=(
        'add:Add a task to the walk-away queue'
        'list:Show pending and completed queued tasks'
        'ls:Show pending and completed queued tasks (alias)'
        'rm:Remove a pending task by index'
        'clear:Empty the queue and stop draining'
        'start:Arm the queue for draining'
        'defer:Decline draining for now'
        'log:Show the walk-away run journal (drains, breaker trips)'
    )

    # Tag subcommands with descriptions
    local -a tag_cmds
    tag_cmds=(
        'add:Add a tag to the current session'
        'rm:Remove a tag from the current session'
        'list:Show tags for a session'
    )

    # -list/-ls options with descriptions
    local -a list_opts
    list_opts=(
        '--tag:List only sessions carrying a tag'
        '--archived:List only archived sessions'
    )

    # Update subcommands with descriptions
    local -a update_cmds
    update_cmds=(
        '--check:Check for updates without installing'
        '-c:Check for updates (alias)'
        '--force:Force reinstall even if up to date'
        '-f:Force reinstall (alias)'
    )

    # Global flags with descriptions
    local -a global_flags
    global_flags=(
        '-list:List all sessions'
        '-ls:List all sessions (alias)'
        '-adopt:Adopt current directory as a session'
        '-remove:Remove a session'
        '-rm:Remove a session (alias)'
        '-whoami:Show the current actor (multi-person sessions)'
        '-who:Show who contributed to shared memory/narrative'
        '-secrets:Manage session secrets'
        '-checkpoint:Save or manage session checkpoints'
        '-queue:Manage the session walk-away queue'
        '-msg:Send a message to another session'
        '-spawn:Open a session in a cs-owned tmux window'
        '-conversations:Show the session'\''s conversation chain'
        '-live:List sessions running right now on this machine'
        '-usage:Per-session token usage over rate-limit windows'
        '-tag:Manage session tags'
        '-archive:Archive a session (hidden from listings)'
        '-unarchive:Restore an archived session'
        '-status:Set or show this session'\''s advertised status'
        '-search:Search across all sessions'
        '-lint:Flag AI-slop prose tells in files'
        '-statusline:Manage the cs status line (enable|disable)'
        '-detect-theme:Detect terminal background theme'
        '-doctor:Run health checks'
        '-diag:Run health checks (alias)'
        '-update:Update cs to latest version'
        '-uninstall:Uninstall cs'
        '-help:Show help message'
        '-h:Show help message (alias)'
        '-version:Show version'
        '-v:Show version (alias)'
    )

    # Determine context
    local in_secrets=false in_update=false in_checkpoint=false in_queue=false in_tag=false in_list=false has_session=false after_remove=false after_archive=false
    local i word

    for ((i=2; i < CURRENT; i++)); do
        word="${words[i]}"
        case "$word" in
            -secrets) in_secrets=true; in_update=false; in_checkpoint=false; in_queue=false; in_tag=false; in_list=false ;;
            -update) in_update=true; in_secrets=false; in_checkpoint=false; in_queue=false; in_tag=false; in_list=false ;;
            -checkpoint) in_checkpoint=true; in_secrets=false; in_update=false; in_queue=false; in_tag=false; in_list=false ;;
            -queue) in_queue=true; in_secrets=false; in_update=false; in_checkpoint=false; in_tag=false; in_list=false ;;
            -tag) in_tag=true; in_secrets=false; in_update=false; in_checkpoint=false; in_queue=false; in_list=false ;;
            -list|-ls) in_list=true; in_secrets=false; in_update=false; in_checkpoint=false; in_queue=false; in_tag=false ;;
            -remove|-rm) after_remove=true ;;
            -archive|-unarchive) after_archive=true ;;
            -*) ;;
            *)
                if ! $in_secrets && ! $after_remove && ! $in_update && ! $in_checkpoint && ! $in_queue && ! $in_tag && ! $in_list && ! $after_archive; then
                    has_session=true
                fi
                ;;
        esac
    done

    # Context: global `cs -msg <session>` / `cs -spawn <session>` — the first arg
    # is a session name (the mail target, or the session to open in tmux). Only
    # the first positional; later -msg args are free-text body.
    if [[ $CURRENT -eq 3 && ( "${words[2]}" == "-msg" || "${words[2]}" == "-spawn" ) ]]; then
        _cs_sessions
        return
    fi

    # Context: after -remove/-rm. These verbs take several names, so every
    # positional past the flag completes, not just the first.
    if $after_remove; then
        _cs_sessions
        return
    fi

    # Context: after -archive/-unarchive (multi-name)
    if $after_archive; then
        _cs_sessions
        return
    fi

    # Context: after -update
    if $in_update; then
        _describe 'update command' update_cmds
        return
    fi

    # Context: after -secrets
    if $in_secrets; then
        _describe 'secrets command' secrets_cmds
        return
    fi

    # Context: after -checkpoint
    if $in_checkpoint; then
        _describe 'checkpoint command' checkpoint_cmds
        return
    fi

    # Context: after -queue
    if $in_queue; then
        _describe 'queue command' queue_cmds
        return
    fi

    # Context: after -tag
    if $in_tag; then
        _describe 'tag command' tag_cmds
        return
    fi

    # Context: after -list/-ls
    if $in_list; then
        _describe 'list option' list_opts
        return
    fi

    # Context: after session name
    if $has_session; then
        local -a session_opts
        session_opts=(
            '-secrets:Run secrets command'
            '-queue:Manage the session walk-away queue'
            '-msg:Send a message to another session'
            '-conversations:Show the session'\''s conversation chain'
            '-usage:Show per-conversation token usage for this session'
            '-tag:Manage session tags'
            '--force:Override active session lock'
            '--merge:Merge a task worktree back and remove it'
        )
        _describe 'option' session_opts
        return
    fi

    # First argument: session names and global flags. Offer both, so that a bare
    # `cs <TAB>` answers "what can I type here" in full. A leading dash rules out
    # every session name, so skip enumerating them (and the cs call it costs).
    if [[ $CURRENT -eq 2 ]]; then
        if [[ "$words[CURRENT]" == -* ]]; then
            _describe 'command' global_flags
            return
        fi
        local ret=1
        _cs_sessions && ret=0
        _describe 'command' global_flags && ret=0
        return $ret
    fi

    return 1
}

_cs "$@"
