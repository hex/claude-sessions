#compdef cs
# ABOUTME: Zsh completion script for cs (Claude Code session manager)
# ABOUTME: Provides tab-completion for session names, commands, and subcommands

_cs() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    # Helper: get session names
    _cs_sessions() {
        local sessions_root="${CS_SESSIONS_ROOT:-$HOME/.claude-sessions}"
        local -a sessions session_descs
        if [[ -d "$sessions_root" ]]; then
            sessions=("$sessions_root"/*(N/:t))
        fi
        # Use _describe so zsh shows a menu even when one name is an
        # exact prefix of another (e.g., "comfy" and "comfy-nodes")
        for s in "${sessions[@]}"; do
            session_descs+=("${s}:session")
        done
        _describe 'session' session_descs
    }

    # Secrets subcommands with descriptions
    local -a secrets_cmds
    secrets_cmds=(
        'set:Store a secret'
        'store:Store a secret (alias)'
        'get:Retrieve a secret value'
        'list:List all secrets'
        'ls:List all secrets (alias)'
        'delete:Delete a secret'
        'rm:Delete a secret (alias)'
        'purge:Delete ALL secrets'
        'export:Export as environment variables'
        'export-file:Export to encrypted file'
        'import-file:Import from encrypted file'
        'migrate:Migrate plaintext secrets'
        'backend:Show storage backend'
    )

    # Checkpoint subcommands with descriptions
    local -a checkpoint_cmds
    checkpoint_cmds=(
        'list:List checkpoints for current session'
        'show:Print a specific checkpoint'
    )

    # Queue subcommands with descriptions
    local -a queue_cmds
    queue_cmds=(
        'add:Add a task to the walk-away queue'
        'list:Show pending and completed queued tasks'
        'ls:Show pending and completed queued tasks (alias)'
        'rm:Remove a pending task by index'
        'clear:Empty the queue and stop draining'
        'start:Arm the queue for draining'
        'defer:Decline draining for now'
    )

    # Update subcommands with descriptions
    local -a update_cmds
    update_cmds=(
        '--check:Check for updates without installing'
        '-c:Check for updates (alias)'
        '--force:Force reinstall even if up to date'
        '-f:Force reinstall (alias)'
    )

    # Global flags with descriptions
    local -a global_flags
    global_flags=(
        '-list:List all sessions'
        '-ls:List all sessions (alias)'
        '-adopt:Adopt current directory as a session'
        '-remove:Remove a session'
        '-rm:Remove a session (alias)'
        '-whoami:Show the current actor (multi-person sessions)'
        '-who:Show who contributed to shared memory/narrative'
        '-secrets:Manage session secrets'
        '-checkpoint:Save or manage session checkpoints'
        '-queue:Manage the session walk-away queue'
        '-search:Search across all sessions'
        '-lint:Flag AI-slop prose tells in files'
        '-statusline:Manage the cs status line (enable|disable)'
        '-detect-theme:Detect terminal background theme'
        '-doctor:Run health checks'
        '-diag:Run health checks (alias)'
        '-update:Update cs to latest version'
        '-uninstall:Uninstall cs'
        '-help:Show help message'
        '-h:Show help message (alias)'
        '-version:Show version'
        '-v:Show version (alias)'
    )

    # Determine context
    local in_secrets=false in_update=false in_checkpoint=false in_queue=false has_session=false after_remove=false
    local i word

    for ((i=2; i < CURRENT; i++)); do
        word="${words[i]}"
        case "$word" in
            -secrets) in_secrets=true; in_update=false; in_checkpoint=false; in_queue=false ;;
            -update) in_update=true; in_secrets=false; in_checkpoint=false; in_queue=false ;;
            -checkpoint) in_checkpoint=true; in_secrets=false; in_update=false; in_queue=false ;;
            -queue) in_queue=true; in_secrets=false; in_update=false; in_checkpoint=false ;;
            -remove|-rm) after_remove=true ;;
            -*) ;;
            *)
                if ! $in_secrets && ! $after_remove && ! $in_update && ! $in_checkpoint && ! $in_queue; then
                    has_session=true
                fi
                ;;
        esac
    done

    # Context: after -remove/-rm
    if $after_remove && [[ $CURRENT -eq 3 ]]; then
        _cs_sessions
        return
    fi

    # Context: after -update
    if $in_update; then
        _describe 'update command' update_cmds
        return
    fi

    # Context: after -secrets
    if $in_secrets; then
        _describe 'secrets command' secrets_cmds
        return
    fi

    # Context: after -checkpoint
    if $in_checkpoint; then
        _describe 'checkpoint command' checkpoint_cmds
        return
    fi

    # Context: after -queue
    if $in_queue; then
        _describe 'queue command' queue_cmds
        return
    fi

    # Context: after session name
    if $has_session; then
        local -a session_opts
        session_opts=(
            '-secrets:Run secrets command'
            '-queue:Manage the session walk-away queue'
            '--force:Override active session lock'
            '--merge:Merge a task worktree back and remove it'
        )
        _describe 'option' session_opts
        return
    fi

    # First argument: session names and global flags
    if [[ $CURRENT -eq 2 ]]; then
        if [[ "$words[CURRENT]" == -* ]]; then
            _describe 'command' global_flags
        else
            _cs_sessions
        fi
        return
    fi

    return 1
}

_cs "$@"
